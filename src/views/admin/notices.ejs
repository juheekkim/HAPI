<div class="admin-nav">
  <span class="admin-nav-title">⚙ 관리자 페이지</span>
  <span>|</span>
  <span>공지사항 관리</span>
</div>

<div class="admin-tabs">
  <a href="/admin/apis" class="admin-tab">🧩 API 등록/관리</a>
  <a href="/admin/codes" class="admin-tab">🔖 코드 관리</a>
  <a href="/admin/menus" class="admin-tab">🗂 메뉴 관리</a>
  <a href="/admin/roles" class="admin-tab">🔑 권한 그룹 관리</a>
  <a href="/admin/partner-roles" class="admin-tab">🧑‍💼 사용자별 권한관리</a>
  <a href="/admin/partners" class="admin-tab">👤 파트너사 코드 신청</a>
  <a href="/admin/firewall" class="admin-tab">🔓 방화벽·토큰 신청</a>
  <a href="/admin/inquiries" class="admin-tab">💬 문의 확인</a>
  <a href="/admin/notices" class="admin-tab active">📢 공지사항 관리</a>
</div>

<div class="admin-content">
  <div class="admin-section-title" style="display:flex;align-items:center;justify-content:space-between;">
    <span>공지사항 목록</span>
    <button class="btn btn-primary btn-sm" onclick="openCreateModal()">+ 새 공지 등록</button>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th style="width:44px;text-align:center;background:#d9e8fb;color:#5a7194;">No</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;width:80px;">태그</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;width:80px;">구분</th>
        <th style="text-align:left;background:#d9e8fb;color:#5a7194;">제목</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;width:180px;">등록일시</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;width:120px;">노출여부</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;width:150px;">관리</th>
      </tr>
    </thead>
    <tbody>
      <% if (notices.length === 0) { %>
      <tr><td colspan="7" style="text-align:center;color:#8a9bb0;padding:32px;">등록된 공지사항이 없습니다.</td></tr>
      <% } %>
      <% notices.forEach((n, idx) => { const rowNo = notices.length - idx; %>
      <tr>
        <td style="text-align:center;color:#8a9bb0;"><%= rowNo %></td>
        <td style="text-align:center;">
          <span class="notice-tag tag-<%= n.tag_type %>"><%= n.tag %></span>
        </td>
        <td style="text-align:center;font-size:12px;color:#4a5568;">
          <% if (n.tag_type === 'new') { %>새소식
          <% } else if (n.tag_type === 'update') { %>업데이트
          <% } else { %>공지<% } %>
        </td>
        <td style="max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= n.title %></td>
        <td class="mono" style="text-align:center;font-size:12px;">
          <%= n.created_at ? new Date(n.created_at).toLocaleString('sv-SE', {timeZone:'Asia/Seoul'}).replace('T',' ').slice(0,16) : '-' %>
        </td>
        <td style="text-align:center;">
          <form action="/admin/notices/<%= n.id %>/toggle-visible" method="POST" style="display:inline;">
            <input type="checkbox" <%= n.is_visible ? 'checked' : '' %> onchange="this.form.submit();">
          </form>
        </td>
        <td style="text-align:center;">
          <div class="action-btns" style="justify-content:center;">
            <button class="btn btn-sm btn-edit-outline"
              onclick="openEditModal(<%= n.id %>, `<%= (n.tag||'').replace(/`/g,'\\`') %>`, `<%= n.tag_type %>`, `<%= (n.title||'').replace(/`/g,'\\`') %>`, `<%= (n.content||'').replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`, <%= n.is_visible %>)">
              수정
            </button>
            <form action="/admin/notices/<%= n.id %>/delete" method="POST" style="display:inline;"
              onsubmit="return confirm('공지사항을 삭제하시겠습니까?')">
              <button type="submit" class="btn btn-sm btn-delete-outline">삭제</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- 등록 모달 -->
<div id="createModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:32px 28px;width:560px;max-width:95vw;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
    <h3 style="margin:0 0 20px;font-size:17px;color:#1e40af;">새 공지 등록</h3>
    <form action="/admin/notices" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">태그 텍스트</label>
          <input type="text" name="tag" placeholder="예: 공지 NEW" required
            style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">구분</label>
          <select name="tag_type" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
            <option value="notice">공지</option>
            <option value="new">새소식(NEW)</option>
            <option value="update">업데이트</option>
          </select>
        </div>
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">제목</label>
        <input type="text" name="title" placeholder="공지사항 제목" required
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">내용</label>
        <textarea name="content" rows="5" placeholder="공지 내용을 입력하세요"
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"></textarea>
      </div>
      <div style="margin-bottom:20px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">노출여부</label>
        <select name="is_visible" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">
          <option value="true">노출</option>
          <option value="false">숨김</option>
        </select>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button type="button" onclick="closeCreateModal()"
          style="padding:8px 20px;border:1px solid #d1d5db;border-radius:6px;background:#fff;color:#374151;font-size:13px;cursor:pointer;">취소</button>
        <button type="submit" class="btn btn-primary btn-sm" style="font-size:13px;padding:8px 20px;">등록</button>
      </div>
    </form>
  </div>
</div>

<!-- 수정 모달 -->
<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:32px 28px;width:560px;max-width:95vw;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
    <h3 style="margin:0 0 20px;font-size:17px;color:#1e40af;">공지 수정</h3>
    <form id="editForm" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">태그 텍스트</label>
          <input type="text" id="editTag" name="tag" required
            style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">구분</label>
          <select id="editTagType" name="tag_type" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
            <option value="notice">공지</option>
            <option value="new">새소식(NEW)</option>
            <option value="update">업데이트</option>
          </select>
        </div>
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">제목</label>
        <input type="text" id="editTitle" name="title" required
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">내용</label>
        <textarea id="editContent" name="content" rows="5"
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"></textarea>
      </div>
      <div style="margin-bottom:20px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">노출여부</label>
        <select id="editIsVisible" name="is_visible" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">
          <option value="true">노출</option>
          <option value="false">숨김</option>
        </select>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button type="button" onclick="closeEditModal()"
          style="padding:8px 20px;border:1px solid #d1d5db;border-radius:6px;background:#fff;color:#374151;font-size:13px;cursor:pointer;">취소</button>
        <button type="submit" class="btn btn-primary btn-sm" style="font-size:13px;padding:8px 20px;">저장</button>
      </div>
    </form>
  </div>
</div>

<script>
function openCreateModal() {
  document.getElementById('createModal').style.display = 'flex';
}
function closeCreateModal() {
  document.getElementById('createModal').style.display = 'none';
}
function openEditModal(id, tag, tagType, title, content, isVisible) {
  document.getElementById('editForm').action = '/admin/notices/' + id + '/update';
  document.getElementById('editTag').value = tag;
  document.getElementById('editTagType').value = tagType;
  document.getElementById('editTitle').value = title;
  document.getElementById('editContent').value = content.replace(/\\n/g, '\n');
  document.getElementById('editIsVisible').value = isVisible ? 'true' : 'false';
  document.getElementById('editModal').style.display = 'flex';
}
function closeEditModal() {
  document.getElementById('editModal').style.display = 'none';
}
// 모달 외부 클릭 시 닫기
document.getElementById('createModal').addEventListener('click', function(e) {
  if (e.target === this) closeCreateModal();
});
document.getElementById('editModal').addEventListener('click', function(e) {
  if (e.target === this) closeEditModal();
});
</script>

<div class="api-layout">
  <!-- 좌측 사이드바 -->
  <aside class="api-sidebar">
    <input class="sidebar-search" placeholder="🔍 API 검색" oninput="filterSidebar(this.value)">

    <%# 사이드바는 로그인 role에 매핑된 메뉴만 노출, 임의 depth 재귀 렌더 (menuModel.getApiSidebarByRole) %>
    <% const sb = (typeof sidebar !== 'undefined' ? sidebar : []); %>
    <% if (sb.length === 0) { %>
      <div class="sidebar-group"><div class="sidebar-item" style="color:#8a9bb0;">표시할 API 문서가 없습니다.</div></div>
    <% } else { %>
      <div class="sidebar-group">
        <%- include('_sidebarTree', { nodes: sb, selectedDoc: selectedDoc, depth: 0 }) %>
      </div>
    <% } %>

  </aside>

  <!-- 우측 API 문서 영역 -->
  <div class="api-content">
    <% if (selectedDoc === 'header') { %>
      <div class="breadcrumb">API Reference › 공통 › 헤더</div>
      <div class="api-page-title">헤더</div>
      <div class="api-page-desc">한화리조트 대외 채널 연동을 위한 표준전문 구조 및 헤더 정보입니다.</div>

      <!-- 탭 버튼 -->
      <div style="display:flex; gap:0; margin-bottom:24px; border-bottom:2px solid #dde3ea;">
        <button id="htab-btn-structure" onclick="switchHeaderTab('structure')"
          style="padding:10px 28px; font-size:14px; font-weight:700; border:none; background:none; cursor:pointer; color:#1e6fce; border-bottom:3px solid #1e6fce; margin-bottom:-2px; transition:all 0.15s;">
          📋 전문구조
        </button>
        <button id="htab-btn-headers" onclick="switchHeaderTab('headers')"
          style="padding:10px 28px; font-size:14px; font-weight:700; border:none; background:none; cursor:pointer; color:#8a9bb0; border-bottom:3px solid transparent; margin-bottom:-2px; transition:all 0.15s;">
          🗂 헤더정보
        </button>
      </div>

      <!-- 탭1: 전문구조 -->
      <div id="htab-structure">

        <!-- 표준전문 구조 -->
        <div class="api-section" style="margin-bottom:24px;">
          <div class="api-section-header">
            <h3>표준전문 구조</h3>
          </div>
          <div class="api-section-body">
            <table class="param-table" style="text-align:center;">
              <thead>
                <tr>
                  <th colspan="3" style="text-align:center; background:#1a3a6b; color:#fff; letter-spacing:0.05em;">헤더부</th>
                  <th rowspan="2" style="text-align:center; background:#2c5282; color:#fff; letter-spacing:0.05em; vertical-align:middle;">개별 데이터부</th>
                </tr>
                <tr>
                  <th style="text-align:center; background:#2d4a7a; color:#e2e8f0;">시스템공통부</th>
                  <th style="text-align:center; background:#2d4a7a; color:#e2e8f0;">거래공통부</th>
                  <th style="text-align:center; background:#2d4a7a; color:#e2e8f0;">메시지부</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="mono" style="text-align:center; color:#1a3a6b; font-weight:600;">SystemHeader</td>
                  <td class="mono" style="text-align:center; color:#1a3a6b; font-weight:600;">TransactionHeader</td>
                  <td class="mono" style="text-align:center; color:#1a3a6b; font-weight:600;">MessageHeader</td>
                  <td class="mono" style="text-align:center; color:#1a3a6b; font-weight:600;">Data</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 시스템 정보 -->
        <div class="api-section" style="margin-bottom:24px;">
          <div class="api-section-header">
            <h3>시스템 정보</h3>
          </div>
          <div class="api-section-body">
            <table class="param-table" style="text-align:center;">
              <thead>
                <tr>
                  <th style="text-align:center;">시스템 명</th>
                  <th style="text-align:center;">시스템 코드</th>
                  <th style="text-align:center;">Protocol</th>
                  <th style="text-align:center;">구분</th>
                  <th style="text-align:center;">Source</th>
                  <th style="text-align:center;">Target</th>
                  <th style="text-align:center;">전문 포맷</th>
                  <th style="text-align:center;">문자코드</th>
                  <th style="text-align:center;">비고</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td rowspan="2" style="vertical-align:middle; font-weight:600;">대형법인사업체</td>
                  <td rowspan="2" class="mono" style="vertical-align:middle; font-weight:600; color:#1a3a6b;">LCB</td>
                  <td rowspan="2" style="vertical-align:middle; font-weight:600;">HTTPS</td>
                  <td style="color:#4a5568; font-size:13px;">회원</td>
                  <td style="color:#8a9bb0;">—</td>
                  <td rowspan="2" style="vertical-align:middle; color:#1a3a6b; font-weight:600; white-space:nowrap;">한화 리조트 대외채널 MCI</td>
                  <td rowspan="2" class="mono" style="vertical-align:middle; font-weight:600;">JSON String</td>
                  <td rowspan="2" style="vertical-align:middle; font-weight:600;">UTF-8</td>
                  <td rowspan="2" style="color:#8a9bb0;">—</td>
                </tr>
                <tr>
                  <td style="color:#4a5568; font-size:13px;">비회원</td>
                  <td style="color:#8a9bb0;">—</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 접속정보 -->
        <div class="api-section">
          <div class="api-section-header">
            <h3>접속정보 <span style="font-size:13px; font-weight:400; color:#8a9bb0;">(도메인을 hosts에 설정)</span></h3>
          </div>
          <div class="api-section-body">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
              <!-- 개발 -->
              <div style="border:1.5px solid #dbeafe; border-radius:10px; overflow:hidden;">
                <div style="background:#dbeafe; color:#1e6fce; font-weight:700; font-size:14px; padding:10px 18px; letter-spacing:0.05em;">개발 서버</div>
                <table class="param-table" style="margin:0; border-radius:0; border:none;">
                  <tbody>
                    <tr>
                      <th style="width:90px; background:#eef4ff; color:#1e6fce;">Domain</th>
                      <td class="mono" style="color:#1e6fce;">exgatedev.hanwharesort.co.kr</td>
                    </tr>
                    <tr>
                      <th style="background:#eef4ff; color:#1e6fce;">IP</th>
                      <td class="mono">211.197.235.21</td>
                    </tr>
                    <tr>
                      <th style="background:#eef4ff; color:#1e6fce;">URL</th>
                      <td>
                        <a href="https://exgatedev.hanwharesort.co.kr:443/iGate/LCB/json.jdo" class="mono" style="color:#1e6fce; word-break:break-all; font-size:12px;">
                          https://exgatedev.hanwharesort.co.kr:443/iGate/LCB/json.jdo
                        </a>
                      </td>
                    </tr>
                  </tbody>
                </table>
                <div style="background:#fffbeb; border-top:1px solid #fde68a; padding:10px 16px; font-size:12px; color:#92400e;">
                  ※ 개발 서버의 경우 도메인 등록이 되어 있지 않아 hosts 등록 후 접속 바랍니다.
                </div>
              </div>
              <!-- 운영 -->
              <div style="border:1.5px solid #d6e6f7; border-radius:10px; overflow:hidden;">
                <div style="background:#c3d9f0; color:#0f2d54; font-weight:700; font-size:14px; padding:10px 18px; letter-spacing:0.05em;">운영 서버</div>
                <table class="param-table" style="margin:0; border-radius:0; border:none;">
                  <tbody>
                    <tr>
                      <th style="width:90px; background:#dce9f8; color:#0f2d54;">Domain</th>
                      <td class="mono" style="color:#0f2d54;">exgate.hanwharesort.co.kr</td>
                    </tr>
                    <tr>
                      <th style="background:#dce9f8; color:#0f2d54;">IP</th>
                      <td class="mono">211.197.235.53</td>
                    </tr>
                    <tr>
                      <th style="background:#dce9f8; color:#0f2d54;">URL</th>
                      <td>
                        <span class="mono" style="color:#0f2d54; font-size:12px; word-break:break-all;">
                          https://exgate.hanwharesort.co.kr:443/iGate/LCB/json.jdo
                        </span>
                      </td>
                    </tr>
                  </tbody>
                </table>
                <div style="background:#dce9f8; border-top:1px solid #d6e6f7; padding:10px 16px; font-size:12px; color:#8a9bb0;">
                  &nbsp;
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
      <!-- 탭1 끝 -->

      <!-- 탭2: 헤더정보 -->
      <style>
        /* 헤더정보 테이블(구분/필드명/생성주체/Setting Value)은 컬럼이 많아 실선 없이도 구분되도록
           옅은 세로 구분선 + 줄무늬만 적용 (공통 .param-table 스타일은 건드리지 않음) */
        #htab-headers .header-field-table td + td,
        #htab-headers .header-field-table th + th {
          border-left: 1px solid rgba(15, 23, 42, 0.06);
        }
        #htab-headers .header-field-table tbody tr:nth-child(even) td {
          background: #f9fafb;
        }
        #htab-headers .header-field-table tbody tr:hover td {
          background: #eef4ff;
        }
      </style>
      <div id="htab-headers" style="display:none;">

        <!-- 시스템공통헤더 -->
        <div class="api-section" style="margin-bottom:24px;">
          <div class="api-section-header" onclick="toggleSection(this)">
            <h3>시스템공통헤더 <span class="mono" style="font-size:12px;font-weight:400;color:#8a9bb0;">SystemHeader</span></h3>
            <span class="api-section-toggle">▶ 펼치기</span>
          </div>
          <div class="api-section-body" style="display:none;">
            <%- include('_headerFieldTable', { groups: headerFields.system }) %>
          </div>
        </div>

        <!-- 거래공통헤더 -->
        <div class="api-section" style="margin-bottom:24px;">
          <div class="api-section-header" onclick="toggleSection(this)">
            <h3>거래공통헤더 <span class="mono" style="font-size:12px;font-weight:400;color:#8a9bb0;">TransactionHeader</span></h3>
            <span class="api-section-toggle">▶ 펼치기</span>
          </div>
          <div class="api-section-body" style="display:none;">
            <%- include('_headerFieldTable', { groups: headerFields.transaction }) %>
          </div>
        </div>

        <!-- 메시지헤더 -->
        <div class="api-section" style="margin-bottom:24px;">
          <div class="api-section-header" onclick="toggleSection(this)">
            <h3>메시지헤더 <span class="mono" style="font-size:12px;font-weight:400;color:#8a9bb0;">MessageHeader</span></h3>
            <span class="api-section-toggle">▶ 펼치기</span>
          </div>
          <div class="api-section-body" style="display:none;">
            <p style="font-size:12px; color:#4a5568; background:#f0f7ff; border:1px solid #bfdbfe; border-radius:6px; padding:10px 14px; margin-bottom:12px;">
              💡 메시지 헤더의 각 항목은 채울 필요는 없지만, 메시지 헤더는 존재해야 합니다. ex) <span class="mono">MessageHeader{}</span>
            </p>
            <%- include('_headerFieldTable', { groups: headerFields.message }) %>
          </div>
        </div>

      </div>
      <!-- 탭2 끝 -->

      <script>
      function switchHeaderTab(tab) {
        document.getElementById('htab-structure').style.display = tab === 'structure' ? '' : 'none';
        document.getElementById('htab-headers').style.display   = tab === 'headers'   ? '' : 'none';
        var btnStructure = document.getElementById('htab-btn-structure');
        var btnHeaders   = document.getElementById('htab-btn-headers');
        if (tab === 'structure') {
          btnStructure.style.color = '#1e6fce'; btnStructure.style.borderBottomColor = '#1e6fce';
          btnHeaders.style.color   = '#8a9bb0'; btnHeaders.style.borderBottomColor   = 'transparent';
        } else {
          btnHeaders.style.color   = '#1e6fce'; btnHeaders.style.borderBottomColor   = '#1e6fce';
          btnStructure.style.color = '#8a9bb0'; btnStructure.style.borderBottomColor = 'transparent';
        }
      }
      </script>

    <% } else if (selectedSpec) { %>
      <div class="breadcrumb">
        API Reference ›
        <span><%= selectedSpec.category === 'resort' ? '리조트' : selectedSpec.category === 'estate' ? '에스테이트' : '공통' %></span>
        › <%= selectedSpec.name %>
      </div>
      <div class="api-page-title"><%= selectedSpec.name %></div>
      <div class="api-page-desc"><%= selectedSpec.description %></div>

      <!-- 에러 코드 테이블 (error-codes 도메인) -->
      <% if (selectedSpec.errorCodes && selectedSpec.errorCodes.length > 0) { %>
      <div class="api-section">
        <div class="api-section-header">
          <h3>에러 코드 목록</h3>
        </div>
        <div class="api-section-body">
          <table class="param-table">
            <thead><tr><th>코드</th><th>HTTP 상태</th><th>설명</th></tr></thead>
            <tbody>
              <% selectedSpec.errorCodes.forEach(ec => { %>
              <tr>
                <td class="mono"><%= ec.code %></td>
                <td><%= ec.http %></td>
                <td><%= ec.desc %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- 엔드포인트 목록 -->
      <% if (selectedSpec.endpoints && selectedSpec.endpoints.length > 0) { %>
        <% selectedSpec.endpoints.forEach((ep, idx) => { %>
        <div class="api-section">
          <div class="api-section-header" onclick="toggleSection(this)">
            <h3><%= ep.description %></h3>
            <span class="api-section-toggle">▶ 펼치기</span>
          </div>
          <div class="api-section-body" style="display:none;">
            <div class="api-url">
              <span class="method-badge method-<%= ep.method.toLowerCase() %>"><%= ep.method %></span>
              <%= ep.url %>
            </div>

            <% if (ep.params && ep.params.length > 0) { %>
            <div class="tab-group" id="tabgrp-<%= idx %>">
              <button class="tab-btn active" onclick="switchTab(this, 'params-<%= idx %>')">▼ 요청 파라미터</button>
              <% if (ep.responseExample) { %>
              <button class="tab-btn" onclick="switchTab(this, 'res-<%= idx %>')">▼ 응답 예시</button>
              <% } %>
            </div>

            <div id="params-<%= idx %>">
              <table class="param-table">
                <thead><tr><th>파라미터ID</th><th>파라미터명</th><th>Data type</th><th>필수</th><th>설명</th></tr></thead>
                <tbody>
                  <% ep.params.forEach(p => {
                    // 구버전 데이터(label 없이 desc에 한글명이 들어있던 시절) 호환: label이 없으면
                    // desc 값을 파라미터명으로 보여주고 설명 칸은 비운다(관리자 화면 addParamRow와 동일 규칙).
                    const hasLabel = p.label !== undefined && p.label !== null && p.label !== '';
                    const displayLabel = hasLabel ? p.label : (p.desc || '');
                    const displayDesc = hasLabel ? (p.desc || '') : '';
                  %>
                  <tr>
                    <td><%= p.name %></td>
                    <td><%= displayLabel %></td>
                    <td class="mono type-text"><%= p.type %></td>
                    <td class="<%= p.required ? 'param-req' : '' %>"><%= p.required ? 'Y' : 'N' %></td>
                    <td><%= displayDesc %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (ep.responseExample) { %>
            <div id="res-<%= idx %>" style="display:none">
              <div class="code-block"><%= ep.responseExample %></div>
            </div>
            <% } %>
            <% } %>
          </div>
        </div>
        <% }) %>
      <% } %>

    <% } else { %>
      <div style="padding:60px;text-align:center;color:#8a9bb0">
        <div style="font-size:48px;margin-bottom:16px">📄</div>
        <div>왼쪽에서 API를 선택하세요.</div>
      </div>
    <% } %>
  </div>
</div>

<script>
function toggleSection(header) {
  const body = header.nextElementSibling;
  const toggle = header.querySelector('.api-section-toggle');
  if (body.style.display === 'none') {
    body.style.display = '';
    toggle.textContent = '▼ 접기';
  } else {
    body.style.display = 'none';
    toggle.textContent = '▶ 펼치기';
  }
}

function switchTab(btn, targetId) {
  const group = btn.closest('.api-section-body');
  group.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const sectionBody = btn.closest('.api-section-body');
  sectionBody.querySelectorAll('[id^="params-"], [id^="res-"]').forEach(el => el.style.display = 'none');
  const target = document.getElementById(targetId);
  if (target) target.style.display = '';
}

function filterSidebar(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.sidebar-item').forEach(item => {
    item.style.display = item.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>

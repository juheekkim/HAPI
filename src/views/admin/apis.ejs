<div class="admin-nav">
  <span class="admin-nav-title">⚙ 관리자 페이지</span>
  <span>|</span>
  <span>API 등록/관리</span>
</div>

<div class="admin-tabs">
  <a href="/admin/partners" class="admin-tab">👤 파트너사 코드 신청</a>
  <a href="/admin/firewall" class="admin-tab">🔓 방화벽·토큰 요청</a>
  <a href="/admin/inquiries" class="admin-tab">💬 문의 확인</a>
  <a href="/admin/notices" class="admin-tab">📢 공지사항 관리</a>
  <a href="/admin/apis" class="admin-tab active">🧩 API 등록/관리</a>
</div>

<div class="admin-content">
  <div class="admin-section-title" style="display:flex;align-items:center;justify-content:space-between;">
    <span>등록된 API 목록</span>
    <a href="/admin/apis/new" class="btn btn-primary btn-sm">+ 새 API 등록</a>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th style="width:44px;text-align:center;background:#dbeafe;color:#1e40af;">No</th>
        <th style="text-align:center;background:#dbeafe;color:#1e40af;width:90px;">카테고리</th>
        <th style="text-align:center;background:#dbeafe;color:#1e40af;width:140px;">도메인</th>
        <th style="text-align:left;background:#dbeafe;color:#1e40af;">API 명칭</th>
        <th style="text-align:center;background:#dbeafe;color:#1e40af;width:100px;">엔드포인트</th>
        <th style="text-align:center;background:#dbeafe;color:#1e40af;width:180px;">등록일시</th>
        <th style="text-align:center;background:#dbeafe;color:#1e40af;width:120px;">관리</th>
      </tr>
    </thead>
    <tbody>
      <% if (apis.length === 0) { %>
      <tr><td colspan="7" style="text-align:center;color:#8a9bb0;padding:32px;">등록된 API가 없습니다.</td></tr>
      <% } %>
      <% apis.forEach((a, idx) => { const rowNo = apis.length - idx; %>
      <tr>
        <td style="text-align:center;color:#8a9bb0;"><%= rowNo %></td>
        <td style="text-align:center;font-size:12px;color:#4a5568;">
          <% if (a.category === 'resort') { %>리조트
          <% } else if (a.category === 'estate') { %>에스테이트
          <% } else { %>공통<% } %>
        </td>
        <td class="mono" style="text-align:center;font-size:12px;"><%= a.domain %></td>
        <td style="max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= a.name %></td>
        <td style="text-align:center;"><%= (a.endpoints || []).length %>개</td>
        <td class="mono" style="text-align:center;font-size:12px;">
          <%= a.created_at ? new Date(a.created_at).toLocaleString('sv-SE', {timeZone:'Asia/Seoul'}).replace('T',' ').slice(0,16) : '-' %>
        </td>
        <td style="text-align:center;">
          <div class="action-btns" style="justify-content:center;">
            <a href="/admin/apis/<%= a.id %>/edit" class="btn btn-sm" style="background:#93c5fd;color:#1e40af;border:none;">수정</a>
            <form action="/admin/apis/<%= a.id %>/delete" method="POST" style="display:inline;"
              onsubmit="return confirm('등록된 API를 삭제하시겠습니까?')">
              <button type="submit" class="btn btn-sm" style="background:#fca5a5;color:#b91c1c;border:none;">삭제</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

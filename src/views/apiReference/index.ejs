<script>
function toggleSection(header) {
  const body = header.nextElementSibling;
  const toggle = header.querySelector('.api-section-toggle');
  if (body.style.display === 'none') {
    body.style.display = '';
    toggle.textContent = '▼ 접기';
  } else {
    body.style.display = 'none';
    toggle.textContent = '▶ 펼치기';
  }
}

function filterSidebar(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.sidebar-item').forEach(item => {
    item.style.display = item.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// ── API 테스트(샌드박스) ──────────────────────────────
// 헤더 필드(system/transaction/message)는 컨트롤러가 이미 내려주는 headerFields를 재사용.
// 실제 게이트웨이 봉투: { SystemHeader, TransactionHeader, MessageHeader, Data } 4개 최상위 키
// (Data.<파라미터 접두사>는 배열, 예: Data.ds_search = [ {필드...} ]). 자동 조립은 "기본값"일 뿐이고
// 실행 전 사용자가 구조화 보기/Raw JSON에서 항상 확인·수정할 수 있게 한다.
var headerFieldsData = <%- JSON.stringify(headerFields) %>;

// 일부 variable 필드는 값 형식이 고정 규칙이라(요청, docs/business-rules.md §10) 버튼 클릭 시점
// 기준으로 자동 계산해 채운다. sysCode는 모달 상단 "시스템코드" 입력칸 값(추천값은 ep.description 기반).
// buildHeaderSection(아래 정의, 함수 선언 호이스팅)이 바로 아래 renderStructureExample()에서
// 즉시 호출되므로, 이 const는 그 호출 전에 와야 한다(TDZ).
const HEADER_AUTO_COMPUTE = {
  FRS_RQST_SYS_CD: (sysCode) => sysCode,
  TMSG_CRE_SYS_NM: (sysCode) => sysCode + randomDigits(5),
  STD_TMSG_SEQ_NO: () => randomDigits(1) + String(Date.now()),
  ENVR_INFO_DV_CD: () => 'D',
  FRS_RQST_DTM: () => formatDateTime17(new Date()),
  TMSG_RQST_DTM: () => formatDateTime17(new Date()),
  TMSG_WRTG_DT: () => formatDate8(new Date()),
};

// 전문구조 탭 "전문 예시" 블록 — 아래 buildHeaderSection()(테스트 샌드박스와 동일 로직)을
// 그대로 재사용해 별도 계산 없이 실제 요청 전문 예시를 렌더링한다. buildHeaderSection은
// function 선언(호이스팅)이라 이 시점에 정의보다 먼저 호출해도 안전하다.
(function renderStructureExample() {
  const el = document.getElementById('structureExampleJson');
  if (!el) return;
  // 특정 엔드포인트 문맥이 없는 정적 예시라 시스템코드는 실제 값 대신 플레이스홀더를 사용.
  const examplePlaceholderSysCode = '{시스템코드}';
  const example = {
    SystemHeader: buildHeaderSection(headerFieldsData.system, examplePlaceholderSysCode),
    TransactionHeader: buildHeaderSection(headerFieldsData.transaction, examplePlaceholderSysCode),
    MessageHeader: buildHeaderSection(headerFieldsData.message, examplePlaceholderSysCode),
    Data: { '...': 'API마다 다름 — 왼쪽에서 API를 선택한 뒤 해당 문서의 파라미터 표를 참고' },
  };
  el.textContent = JSON.stringify(example, null, 2);
})();

var specEndpoints = <%- JSON.stringify(selectedSpec ? selectedSpec.endpoints : []) %>;
var currentDomain = <%- JSON.stringify(selectedDoc) %>;
var tryModalEndpointIdx = null;
var currentPayload = {};

// ── 엔드포인트 목록의 "요청 파라미터"/"응답 예시" 표 + "Data부 JSON 샘플" 렌더링 ──────────
// 파라미터명이 "ds_inSearch.CORP_CD"처럼 점 표기라 그대로 한 줄에 나열하면 실제로는
// ds_inSearch라는 데이터셋(배열) 안에 CORP_CD가 들어있는 중첩 구조라는 게 잘 안 보인다(가독성 문제).
// 요청/응답 모두 같은 방식(점 경로를 그룹/리프 트리로 묶고 들여쓰기로 렌더링)으로 통일한다.
// 그룹은 이 포털의 Data 봉투 규칙(business-rules.md §10, 점 표기 접두사는 항상 배열로 감싸짐)에
// 따라 "배열" 배지를 붙이고, 실제 JSON 값이 순수 객체인 경우(응답 쪽에서만 발생 가능)만 "객체"로 표기한다.
function makeGroupRow(name, depth, colspan, isArray) {
  const tr = document.createElement('tr');
  const td = document.createElement('td');
  td.colSpan = colspan;
  td.style.cssText = 'padding:7px 14px; padding-left:' + (14 + depth * 18) + 'px; background:#eef4ff;';
  const badge = document.createElement('span');
  badge.textContent = isArray ? '배열' : '객체';
  badge.style.cssText = 'flex-shrink:0; font-size:10px; font-weight:700; color:#1e6fce; background:#fff;'
    + 'border:1px solid #93c5fd; border-radius:10px; padding:1px 7px; margin-right:8px;';
  td.appendChild(badge);
  const nameSpan = document.createElement('span');
  nameSpan.className = 'mono';
  nameSpan.style.cssText = 'font-weight:700; font-size:12.5px; color:#1e6fce;';
  nameSpan.textContent = name;
  td.appendChild(nameSpan);
  tr.appendChild(td);
  return tr;
}

// 요청 파라미터: ep.params[].name(점 경로, 임의 depth 가능 — apiSpecImportMapper.buildParams의
// Group ▷ 들여쓰기가 그대로 점 경로에 녹아 있음)을 그룹/리프 트리로 묶는다. Map은 삽입 순서를
// 보장하므로 원본 파라미터 나열 순서가 그대로 유지된다.
function buildParamTree(params) {
  const root = { children: new Map() };
  (params || []).forEach((p) => {
    const parts = p.name.split('.');
    let node = root;
    parts.forEach((part, i) => {
      if (!node.children.has(part)) node.children.set(part, { children: new Map() });
      node = node.children.get(part);
      if (i === parts.length - 1) node.param = p;
    });
  });
  return root;
}

function makeParamLeafRow(p, leafName, depth) {
  // 구버전 데이터(label 없이 desc에 한글명이 들어있던 시절) 호환: label이 없으면 desc 값을
  // 파라미터명으로 보여주고 설명 칸은 비운다(관리자 화면 addParamRow와 동일 규칙).
  const hasLabel = p.label !== undefined && p.label !== null && p.label !== '';
  const displayLabel = hasLabel ? p.label : (p.desc || '');
  const displayDesc = hasLabel ? (p.desc || '') : '';
  const tr = document.createElement('tr');
  tr.dataset.paramName = (p.name || '').toLowerCase();
  tr.dataset.paramLeaf = (leafName || '').toLowerCase();
  tr.dataset.paramLabel = (displayLabel || '').toLowerCase();
  const idTd = document.createElement('td');
  idTd.className = 'mono';
  idTd.style.paddingLeft = (14 + depth * 18) + 'px';
  idTd.textContent = leafName;
  idTd.title = p.name; // 전체 점 경로는 툴팁으로 확인 가능
  tr.appendChild(idTd);
  const labelTd = document.createElement('td');
  labelTd.textContent = displayLabel;
  tr.appendChild(labelTd);
  const typeTd = document.createElement('td');
  typeTd.className = 'mono type-text';
  typeTd.textContent = p.type;
  tr.appendChild(typeTd);
  const reqTd = document.createElement('td');
  if (p.required) reqTd.className = 'param-req';
  reqTd.textContent = p.required ? 'Y' : 'N';
  tr.appendChild(reqTd);
  const descTd = document.createElement('td');
  descTd.textContent = displayDesc;
  tr.appendChild(descTd);
  return tr;
}

function renderParamTreeRows(tbody, node, depth) {
  node.children.forEach((child, key) => {
    if (child.children.size > 0) {
      tbody.appendChild(makeGroupRow(key, depth, 5, true));
      renderParamTreeRows(tbody, child, depth + 1);
    } else if (child.param) {
      tbody.appendChild(makeParamLeafRow(child.param, key, depth));
    }
  });
}

function renderRequestTable(idx, params) {
  const table = document.getElementById('req-table-' + idx);
  if (!table) return;
  const tbody = table.querySelector('tbody');
  renderParamTreeRows(tbody, buildParamTree(params), 0);
}

// 응답 예시: 필드별 라벨/필수/설명 메타데이터 없이 JSON 텍스트만 저장돼 있어(엑셀·이미지 자동입력은
// OUTPUT 필드를 예시 JSON으로만 남김, apiSpecImportMapper.buildResponseExampleObject), 파싱한 JSON을
// 그대로 재귀 순회해 그룹(객체/배열)/리프(값) 행 목록을 만든다. 최상위 컨테이너 자체는 그룹 행 없이
// 바로 그 자식들을 depth 0부터 펼친다(요청 파라미터 표의 최상위 파라미터들과 톤을 맞추기 위함).
function buildResponseRows(root) {
  const rows = [];
  function walk(value, name, depth, isRoot) {
    if (Array.isArray(value)) {
      if (!isRoot) rows.push({ kind: 'group', name, depth, isArray: true });
      if (value.length === 0) return;
      const item = value[0];
      const childDepth = isRoot ? depth : depth + 1;
      if (item !== null && typeof item === 'object' && !Array.isArray(item)) {
        Object.keys(item).forEach((k) => walk(item[k], k, childDepth, false));
      } else {
        walk(item, null, childDepth, false);
      }
      return;
    }
    if (value !== null && typeof value === 'object') {
      if (!isRoot) rows.push({ kind: 'group', name, depth, isArray: false });
      const childDepth = isRoot ? depth : depth + 1;
      Object.keys(value).forEach((k) => walk(value[k], k, childDepth, false));
      return;
    }
    let type = 'String';
    if (typeof value === 'number') type = 'Number';
    else if (typeof value === 'boolean') type = 'Boolean';
    rows.push({ kind: 'leaf', name, depth, type, example: value === null ? '' : String(value) });
  }
  walk(root, null, 0, true);
  return rows;
}

function makeResponseLeafRow(r) {
  const tr = document.createElement('tr');
  tr.dataset.responseField = (r.name || '').toLowerCase();
  const idTd = document.createElement('td');
  idTd.className = 'mono';
  idTd.style.paddingLeft = (14 + r.depth * 18) + 'px';
  idTd.textContent = r.name;
  tr.appendChild(idTd);
  tr.appendChild(document.createElement('td')); // 필드명 — 응답 예시엔 라벨 메타데이터가 없어 항상 빈 칸
  const typeTd = document.createElement('td');
  typeTd.className = 'mono type-text';
  typeTd.textContent = r.type;
  tr.appendChild(typeTd);
  const exTd = document.createElement('td');
  exTd.className = 'mono';
  exTd.textContent = r.example;
  tr.appendChild(exTd);
  tr.appendChild(document.createElement('td')); // 설명 — 응답 예시엔 설명 메타데이터가 없어 항상 빈 칸
  return tr;
}

function renderResponseTable(idx, responseExample) {
  const table = document.getElementById('res-table-' + idx);
  if (!table) return null;
  const tbody = table.querySelector('tbody');
  let parsed;
  try {
    parsed = JSON.parse(responseExample);
  } catch (e) {
    parsed = null;
  }
  if (!parsed || typeof parsed !== 'object') {
    const tr = document.createElement('tr');
    const td = document.createElement('td');
    td.colSpan = 5;
    td.textContent = 'JSON 형식이 아니어서 표로 변환할 수 없습니다.';
    tr.appendChild(td);
    tbody.appendChild(tr);
    return null;
  }
  buildResponseRows(parsed).forEach((r) => {
    tbody.appendChild(r.kind === 'group' ? makeGroupRow(r.name, r.depth, 5, r.isArray) : makeResponseLeafRow(r));
  });
  return parsed;
}

// 일부 Data 필드는 여러 API에 공통으로 등장하고 테스트 환경 기준값이 정해져 있어(요청)
// 리프 필드명(접두사 제외) 기준으로 자동 채운다. 여전히 편집 가능. buildDataSection(아래,
// 함수 선언은 호이스팅됨)이 참조하므로 const는 첫 사용(바로 아래 forEach) 전에 와야 한다.
const DATA_FIELD_DEFAULTS = {
  CORP_CD: '1000',
};

// buildDataSection()은 테스트 샌드박스 팝업에서도 쓰는 함수(아래 정의, 함수 선언은 호이스팅되어
// 이 시점에 먼저 호출해도 안전)를 그대로 재사용해, 요청 파라미터를 접두사 기준으로 그룹핑한
// 실제 전송 봉투 형태(Data.ds_search = [ {...} ] 등)를 요청 파라미터 표와 별도로 보여준다.
function renderRequestSample(idx, params) {
  const el = document.getElementById('req-sample-' + idx);
  if (!el) return;
  el.textContent = JSON.stringify({ Data: buildDataSection(params) }, null, 2);
}

// 실제 게이트웨이 응답 봉투는 최상위 키가 Data인 형태(business-rules.md §10, 요청 봉투와 동일 톤)라
// 요청 샘플과 짝을 맞춰 { "Data": {...} }로 감싼다. renderResponseTable이 이미 파싱한 결과를 그대로
// 재사용해 JSON.parse를 두 번 하지 않는다. 파싱 실패(JSON 아닌 값) 시엔 원문을 그대로 보여준다.
function renderResponseSample(idx, parsed, rawText) {
  const el = document.getElementById('res-sample-' + idx);
  if (!el) return;
  el.textContent = parsed ? JSON.stringify({ Data: parsed }, null, 2) : rawText;
}

specEndpoints.forEach((ep, idx) => {
  if (ep.params && ep.params.length > 0) {
    renderRequestTable(idx, ep.params);
    renderRequestSample(idx, ep.params);
  }
  if (ep.responseExample) {
    const parsed = renderResponseTable(idx, ep.responseExample);
    renderResponseSample(idx, parsed, ep.responseExample);
  }
});

function pad(n, len) {
  return String(n).padStart(len, '0');
}

function randomDigits(len) {
  let s = '';
  for (let i = 0; i < len; i++) s += Math.floor(Math.random() * 10);
  return s;
}

// YYYYMMDDHHMMSSTTT(17자리, 밀리초 3자리 포함).
function formatDateTime17(d) {
  return '' + d.getFullYear() + pad(d.getMonth() + 1, 2) + pad(d.getDate(), 2)
    + pad(d.getHours(), 2) + pad(d.getMinutes(), 2) + pad(d.getSeconds(), 2) + pad(d.getMilliseconds(), 3);
}

// YYYYMMDD(8자리).
function formatDate8(d) {
  return '' + d.getFullYear() + pad(d.getMonth() + 1, 2) + pad(d.getDate(), 2);
}

// header_fields.setting_type/setting_value/required_request 메타데이터 기반 자동입력 규칙.
// - required_request === '×' (요청측 미생성): 키는 남기고 값은 null(관측된 실제 봉투 예시 기준).
// - HEADER_AUTO_COMPUTE에 등록된 필드(fieldNameEn 기준): 위 계산 규칙으로 자동 채움(여전히 편집 가능).
// - setting_type === 'fix': setting_value를 그대로 채운다(값을 추측하지 않음).
// - setting_type === 'variable' | 'none'(그 외): 서비스/호출마다 달라질 수 있어 자동으로 채우지 않고
//   값은 null(요청, 빈 문자열 "" 대신)로 두고 사용자가 직접 입력한다. UI에서 variable=필수,
//   none=선택으로 구분 표시한다(fieldKind가 그 구분을 담당). 입력창 자체는 null이어도 빈칸으로 보인다
//   (makeFieldRow의 value !== null ? value : '' 처리).
function computeHeaderDefault(field, sysCode) {
  if (field.requiredRequest === '×') return null;
  if (HEADER_AUTO_COMPUTE[field.fieldNameEn]) return HEADER_AUTO_COMPUTE[field.fieldNameEn](sysCode || '');
  if (field.settingType === 'fix') return field.settingValue;
  return null;
}

function fieldKind(settingType) {
  if (settingType === 'fix') return 'fix';
  if (settingType === 'variable') return 'variable';
  return 'none';
}

function buildHeaderSection(groups, sysCode) {
  const out = {};
  (groups || []).forEach(g => (g.fields || []).forEach(f => {
    out[f.fieldNameEn] = computeHeaderDefault(f, sysCode);
  }));
  return out;
}

// INTF_ID = 시스템코드(URL 경로) + "00" + SVC ID(ep.url). 시스템코드 입력칸(trySystemCode)이
// 바뀌면 onSystemCodeChange()가 이 값을 다시 계산해 잠긴 입력칸에 반영한다.
function computeIntfId(ep) {
  const sysCode = (document.getElementById('trySystemCode').value || '').trim();
  return sysCode + '00' + (ep ? ep.url : '');
}

function onSystemCodeChange() {
  const ep = specEndpoints[tryModalEndpointIdx];
  if (!ep || !currentPayload.SystemHeader) return;
  const intfId = computeIntfId(ep);
  currentPayload.SystemHeader.INTF_ID = intfId;
  const el = document.getElementById('tryFieldIntfId');
  if (el) el.value = intfId;
}

// 필수/선택 파라미터 모두 대상(필수 여부는 UI 배지로 구분). 이름에 점(.)이 있으면
// (예: ds_inSearch.CORP_CD) 접두사를 Data 하위의 배열 키로 그룹핑한다
// (실제 관측된 봉투 예시: Data.ds_search = [ {필드...} ]). 점이 없으면 Data 바로 아래.
// DATA_FIELD_DEFAULTS에 없는 필드는 빈 문자열 "" 대신 null로 둔다(요청).
function buildDataSection(params) {
  const top = {};
  const groups = {};
  (params || []).forEach(p => {
    const parts = p.name.split('.');
    if (parts.length === 1) {
      top[parts[0]] = DATA_FIELD_DEFAULTS[parts[0]] || null;
    } else {
      const prefix = parts[0];
      const leaf = parts.slice(1).join('.');
      groups[prefix] = groups[prefix] || {};
      groups[prefix][leaf] = DATA_FIELD_DEFAULTS[leaf] || null;
    }
  });
  const data = Object.assign({}, top);
  Object.keys(groups).forEach((prefix) => { data[prefix] = [groups[prefix]]; });
  return data;
}

// kind: 'fix'(자동 채워짐, 확인만) | 'variable'(반드시 채워야 함) | 'none'(비워둬도 됨)
// | 'locked'(테스트 대상 API에서 자동 산출, 수정 불가 — RECV_SVC_CD/INTF_ID 전용)
var FIELD_KIND_STYLE = {
  fix:      { text: '고정값',        color: '#64748b', bg: '#f1f5f9', border: '#cbd5e1' },
  variable: { text: '필수 입력',     color: '#c2410c', bg: '#fff7ed', border: '#fb923c' },
  none:     { text: '선택',          color: '#94a3b8', bg: '#fafbfc', border: '#e2e8f0' },
  locked:   { text: '자동 고정(수정불가)', color: '#475569', bg: '#e2e8f0', border: '#94a3b8' },
};

function makeFieldRow(labelText, value, onInput, kind, placeholderHint, inputId) {
  const style = FIELD_KIND_STYLE[kind] || FIELD_KIND_STYLE.none;
  const row = document.createElement('div');
  row.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:5px 8px;'
    + 'border-left:3px solid ' + style.border + ';background:' + style.bg + ';border-radius:4px;';
  const label = document.createElement('label');
  label.style.cssText = 'width:230px;flex-shrink:0;font-size:12px;color:#4a5568;display:flex;align-items:center;gap:6px;';
  const badge = document.createElement('span');
  badge.textContent = style.text;
  badge.style.cssText = 'flex-shrink:0;font-size:10px;font-weight:700;color:' + style.color + ';'
    + 'background:#fff;border:1px solid ' + style.border + ';border-radius:10px;padding:1px 7px;';
  const labelSpan = document.createElement('span');
  labelSpan.textContent = labelText;
  label.appendChild(badge);
  label.appendChild(labelSpan);
  const input = document.createElement('input');
  input.style.cssText = 'flex:1;padding:6px 8px;border:1px solid #dde3ea;border-radius:5px;font-size:12px;font-family:inherit;';
  input.value = value !== undefined && value !== null ? value : '';
  if (placeholderHint) input.placeholder = placeholderHint;
  if (inputId) input.id = inputId;
  if (kind === 'locked') {
    input.readOnly = true;
    input.style.background = '#eef1f4';
    input.style.color = '#475569';
    input.style.cursor = 'not-allowed';
  } else {
    input.oninput = () => onInput(input.value);
  }
  row.appendChild(label);
  row.appendChild(input);
  return row;
}

function renderStructuredView(ep) {
  const container = document.getElementById('tryStructured');
  container.innerHTML = '';

  // 실제 봉투는 SystemHeader/TransactionHeader/MessageHeader/Data 4개 최상위 키로 구성된다.
  [
    ['SystemHeader', '시스템 공통헤더', headerFieldsData.system],
    ['TransactionHeader', '거래 공통헤더', headerFieldsData.transaction],
    ['MessageHeader', '메시지 헤더', headerFieldsData.message],
  ].forEach(([sectionKey, title, groups]) => {
    const fields = (groups || []).flatMap(g => g.fields || []).filter(f => f.requiredRequest !== '×');
    if (fields.length === 0) return;
    currentPayload[sectionKey] = currentPayload[sectionKey] || {};
    const box = document.createElement('div');
    box.style.marginBottom = '16px';
    const h = document.createElement('div');
    h.style.cssText = 'font-weight:700;font-size:13px;color:#1a3a6b;margin-bottom:8px;';
    h.textContent = title;
    box.appendChild(h);
    fields.forEach(f => {
      // RECV_SVC_CD(수신서비스코드)와 INTF_ID(인터페이스ID)는 테스트 대상 API 자체로 결정되는
      // 값이라 setting_type과 무관하게 자동 산출하고 수정을 막는다(사용자 지시).
      if (sectionKey === 'SystemHeader' && f.fieldNameEn === 'RECV_SVC_CD') {
        currentPayload.SystemHeader.RECV_SVC_CD = ep.url;
        box.appendChild(makeFieldRow(
          f.fieldNameKo + ' (' + f.fieldNameEn + ')', ep.url, null, 'locked', '', 'tryFieldRecvSvcCd'
        ));
        return;
      }
      if (sectionKey === 'SystemHeader' && f.fieldNameEn === 'INTF_ID') {
        const intfId = computeIntfId(ep);
        currentPayload.SystemHeader.INTF_ID = intfId;
        box.appendChild(makeFieldRow(
          f.fieldNameKo + ' (' + f.fieldNameEn + ')', intfId, null, 'locked', '', 'tryFieldIntfId'
        ));
        return;
      }

      const kind = fieldKind(f.settingType);
      // variable은 값 형식을 짐작할 수 있는 setting_value(예: "Random(1) + unix time(13)")를
      // placeholder로만 보여준다(실제 입력값으로 자동 채우지 않음).
      const hint = kind === 'variable' ? (f.settingValue || '') : '';
      box.appendChild(makeFieldRow(
        f.fieldNameKo + ' (' + f.fieldNameEn + ')',
        currentPayload[sectionKey][f.fieldNameEn],
        (v) => { currentPayload[sectionKey][f.fieldNameEn] = v; },
        kind,
        hint
      ));
    });
    container.appendChild(box);
  });

  const params = ep.params || [];
  if (params.length > 0) {
    currentPayload.Data = currentPayload.Data || {};
    const box = document.createElement('div');
    const h = document.createElement('div');
    h.style.cssText = 'font-weight:700;font-size:13px;color:#1a3a6b;margin-bottom:8px;';
    h.textContent = 'Data';
    box.appendChild(h);
    params.forEach(p => {
      const parts = p.name.split('.');
      // Data.<prefix>는 배열(예: ds_search: [ {...} ]) — 항상 0번째 원소를 편집한다.
      let cur = currentPayload.Data;
      let leafKey = parts[parts.length - 1];
      if (parts.length > 1) {
        const prefix = parts[0];
        cur[prefix] = cur[prefix] || [{}];
        cur = cur[prefix][0];
        leafKey = parts.slice(1).join('.');
      }
      const target = cur;
      // API 스펙의 필수(Y) 파라미터만 "필수 입력", 나머지는 "선택".
      box.appendChild(makeFieldRow(
        (p.label || p.desc || p.name) + ' (' + p.name + ')',
        target[leafKey],
        (v) => { target[leafKey] = v; },
        p.required ? 'variable' : 'none'
      ));
    });
    container.appendChild(box);
  }
}

function switchTryView(view) {
  const isRaw = view === 'raw';
  if (isRaw) {
    document.getElementById('tryRawJson').value = JSON.stringify(currentPayload, null, 2);
  } else {
    try {
      currentPayload = JSON.parse(document.getElementById('tryRawJson').value);
    } catch (e) {
      alert('JSON 형식이 올바르지 않아 구조화 보기로 반영하지 못했습니다: ' + e.message);
      return;
    }
    renderStructuredView(specEndpoints[tryModalEndpointIdx]);
  }
  document.getElementById('tryStructured').style.display = isRaw ? 'none' : '';
  document.getElementById('tryRawWrap').style.display = isRaw ? '' : 'none';
  document.getElementById('tryTabStructured').classList.toggle('active', !isRaw);
  document.getElementById('tryTabRaw').classList.toggle('active', isRaw);
}

function openTryModal(idx) {
  tryModalEndpointIdx = idx;
  const ep = specEndpoints[idx];
  if (!ep) return;

  // URL 경로의 시스템코드는 API마다 다르다(예: OCH, LCB) — description의 "{시스템코드} / ..." 첫 토큰을
  // 추천값으로 채우고, 실행 전 사용자가 직접 확인/수정한다. FRS_RQST_SYS_CD/TMSG_CRE_SYS_NM
  // 자동 채움이 이 값을 사용하므로 currentPayload를 만들기 전에 먼저 확정한다.
  const sysCode = (ep.description || '').split(' / ')[0].trim();
  document.getElementById('trySystemCode').value = sysCode;

  // 실제 봉투 구조: { SystemHeader, TransactionHeader, MessageHeader, Data } 4개 최상위 키.
  currentPayload = {
    SystemHeader: buildHeaderSection(headerFieldsData.system, sysCode),
    TransactionHeader: buildHeaderSection(headerFieldsData.transaction, sysCode),
    MessageHeader: buildHeaderSection(headerFieldsData.message, sysCode),
    Data: buildDataSection(ep.params),
  };

  document.getElementById('tryModalTitle').textContent = ep.description + ' · ' + ep.url;
  const resultPanel = document.getElementById('tryResultPanel');
  resultPanel.style.display = 'none';
  resultPanel.textContent = '';
  document.getElementById('tryStructured').style.display = '';
  document.getElementById('tryRawWrap').style.display = 'none';
  document.getElementById('tryTabStructured').classList.add('active');
  document.getElementById('tryTabRaw').classList.remove('active');
  renderStructuredView(ep);
  document.getElementById('modal-try').style.display = 'flex';
}

function closeTryModal() {
  document.getElementById('modal-try').style.display = 'none';
  tryModalEndpointIdx = null;
}

document.getElementById('modal-try').addEventListener('click', function (e) {
  if (e.target === this) closeTryModal();
});

async function runTry() {
  const idx = tryModalEndpointIdx;
  if (idx === null) return;
  const resultPanel = document.getElementById('tryResultPanel');
  const isRawView = document.getElementById('tryRawWrap').style.display !== 'none';

  let payload = currentPayload;
  if (isRawView) {
    try {
      payload = JSON.parse(document.getElementById('tryRawJson').value);
    } catch (e) {
      resultPanel.style.display = '';
      resultPanel.textContent = 'JSON 형식이 올바르지 않습니다: ' + e.message;
      return;
    }
  }

  const runBtn = document.getElementById('tryRunBtn');
  runBtn.disabled = true;
  runBtn.textContent = '실행 중...';
  resultPanel.style.display = '';
  resultPanel.textContent = '요청 전송 중...';

  try {
    const result = await apiClient.post('/api-reference/try', {
      domain: currentDomain,
      endpointIndex: idx,
      systemCode: document.getElementById('trySystemCode').value.trim(),
      body: payload,
    });
    renderTryResult(resultPanel, result);
  } catch (err) {
    resultPanel.textContent = '오류: ' + (err.message || '요청에 실패했습니다.');
  } finally {
    runBtn.disabled = false;
    runBtn.textContent = '실행';
  }
}

function makeRawToggle(panel, raw, expanded) {
  const btn = document.createElement('button');
  btn.type = 'button';
  btn.className = 'btn btn-outline';
  btn.style.cssText = 'padding:4px 10px;font-size:11px;margin-bottom:8px;';
  const block = document.createElement('div');
  block.className = 'code-block';
  block.style.cssText = 'font-size:12px;' + (expanded ? '' : 'display:none;');
  block.textContent = raw;
  const setLabel = () => {
    btn.textContent = block.style.display === 'none' ? '▶ 전체 응답 보기' : '▼ 전체 응답 접기';
  };
  setLabel();
  btn.onclick = () => {
    block.style.display = block.style.display === 'none' ? '' : 'none';
    setLabel();
  };
  panel.appendChild(btn);
  panel.appendChild(block);
}

// 게이트웨이는 정상/오류 모두 SystemHeader/TransactionHeader가 있는 JSON 봉투로 응답한다
// (관측된 실 예시). Data(반환 결과)와 MessageHeader.MSG_DATA_SUB의 MSG_CD/MSG_CTNS(메시지
// 코드/내용, 성공·실패 모두 채워짐)를 요약으로 먼저 보여주고, 전체 원본 응답은 접어서 아래에 둔다.
function renderTryResult(panel, result) {
  panel.innerHTML = '';
  const body = result.body;
  const raw = typeof body === 'string' ? body : JSON.stringify(body, null, 2);
  const isEnvelope = body && typeof body === 'object' && !Array.isArray(body)
    && ('SystemHeader' in body) && ('TransactionHeader' in body);

  const statusLine = document.createElement('div');
  statusLine.style.cssText = 'font-size:12px;color:#8a9bb0;margin-bottom:10px;';
  statusLine.textContent = 'HTTP ' + result.status;
  panel.appendChild(statusLine);

  if (!isEnvelope) {
    const warn = document.createElement('div');
    warn.style.cssText = 'background:#fef2f2;border:1px solid #fca5a5;color:#b91c1c;'
      + 'border-radius:6px;padding:10px 14px;margin-bottom:10px;font-size:12.5px;';
    warn.textContent = '⚠ 예상된 응답 형식(SystemHeader/TransactionHeader 포함 JSON)이 아닙니다. '
      + '필수 파라미터 값을 채웠는지, 시스템코드가 맞는지 확인해 주세요.';
    panel.appendChild(warn);
    makeRawToggle(panel, raw, true);
    return;
  }

  const msgHeader = body.MessageHeader || {};
  const msgResult = msgHeader.MSG_PRCS_RSLT_CD;
  const isError = msgResult && msgResult !== '0';
  const subMsgs = msgHeader.MSG_DATA_SUB || [];

  const summary = document.createElement('div');
  summary.style.cssText = 'border:1px solid ' + (isError ? '#fca5a5' : '#bbf7d0') + ';'
    + 'background:' + (isError ? '#fef2f2' : '#f0fdf4') + ';border-radius:8px;padding:12px 14px;margin-bottom:12px;';

  const summaryTitle = document.createElement('div');
  summaryTitle.style.cssText = 'font-weight:700;font-size:12.5px;margin-bottom:8px;'
    + 'color:' + (isError ? '#b91c1c' : '#15803d') + ';';
  summaryTitle.textContent = isError ? '⚠ 처리 실패' : '✓ 처리 결과';
  summary.appendChild(summaryTitle);

  subMsgs.forEach((m) => {
    const row = document.createElement('div');
    row.style.cssText = 'font-size:12.5px;margin-bottom:4px;color:#1a2332;';
    const codeSpan = document.createElement('span');
    codeSpan.style.cssText = 'font-family:"JetBrains Mono",monospace;font-weight:700;color:#475569;margin-right:8px;';
    codeSpan.textContent = m.MSG_CD || '';
    row.appendChild(codeSpan);
    row.appendChild(document.createTextNode(m.MSG_CTNS || ''));
    summary.appendChild(row);
  });

  const dataLabel = document.createElement('div');
  dataLabel.style.cssText = 'font-weight:700;font-size:12px;color:#4a5568;margin-top:10px;margin-bottom:4px;';
  dataLabel.textContent = 'Data';
  summary.appendChild(dataLabel);

  const hasData = body.Data && typeof body.Data === 'object' && Object.keys(body.Data).length > 0;
  const dataBlock = document.createElement('div');
  dataBlock.className = 'code-block';
  dataBlock.style.cssText = 'font-size:12px;margin:0;';
  dataBlock.textContent = hasData ? JSON.stringify(body.Data, null, 2) : '(비어 있음)';
  summary.appendChild(dataBlock);

  panel.appendChild(summary);
  makeRawToggle(panel, raw, false);
}

function normalizeFocusToken(value) {
  return String(value || '')
    .toLowerCase()
    .replace(/\s+/g, '')
    .replace(/[^a-z0-9_\.가-힣]/g, '');
}

function getScrollContainer(el) {
  let node = el && el.parentElement;
  while (node) {
    const oy = window.getComputedStyle(node).overflowY;
    if ((oy === 'auto' || oy === 'scroll') && node.scrollHeight > node.clientHeight) {
      return node;
    }
    node = node.parentElement;
  }
  return null;
}

function highlightAndScroll(target, rowOnly) {
  if (!target) return;
  const className = rowOnly ? 'api-focus-row' : 'api-focus-target';
  target.classList.add(className);
  // API Reference scrolls inside `.api-content` (overflow-y:auto), not the window.
  const container = getScrollContainer(target);
  if (container) {
    const cRect = container.getBoundingClientRect();
    const tRect = target.getBoundingClientRect();
    // Already fully in view: keep position, just highlight (no re-scroll on repeat clicks).
    const fullyVisible = tRect.top >= cRect.top && tRect.bottom <= cRect.bottom;
    if (!fullyVisible) {
      const top = container.scrollTop + (tRect.top - cRect.top) - 24;
      container.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }
  } else {
    const tRect = target.getBoundingClientRect();
    const fullyVisible = tRect.top >= 0 && tRect.bottom <= window.innerHeight;
    if (!fullyVisible) {
      const y = tRect.top + window.scrollY - 96;
      window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
    }
  }
  setTimeout(() => target.classList.remove(className), 3000);
}

function openSectionByHeader(header) {
  if (!header) return;
  const body = header.nextElementSibling;
  const toggle = header.querySelector('.api-section-toggle');
  if (body && body.style.display === 'none') {
    body.style.display = '';
    if (toggle) toggle.textContent = '▼ 접기';
  }
}

function focusHeaderSection(section) {
  if (!section) return false;
  if (typeof switchHeaderTab === 'function') switchHeaderTab('headers');
  const map = {
    system: '시스템공통헤더',
    transaction: '거래공통헤더',
    message: '메시지헤더',
  };
  const title = map[section];
  if (!title) return false;
  const header = Array.from(document.querySelectorAll('.api-section-header')).find((el) =>
    (el.textContent || '').includes(title)
  );
  if (!header) return false;
  openSectionByHeader(header);
  highlightAndScroll(header.closest('.api-section'));
  return true;
}

function focusHeaderField(section, field) {
  if (!section || !field) return false;
  if (!focusHeaderSection(section)) return false;
  const needle = normalizeFocusToken(field);
  const rows = Array.from(document.querySelectorAll('.header-field-table tbody tr'));
  const row = rows.find((r) => normalizeFocusToken(r.textContent).includes(needle));
  if (!row) return false;
  highlightAndScroll(row, true);
  return true;
}

function openEndpointByIndex(index) {
  if (!Number.isInteger(index) || index < 0) return null;
  const section = document.querySelector('.api-section[data-ep-index="' + index + '"]');
  if (!section) return null;
  const header = section.querySelector('.api-section-header');
  if (header) openSectionByHeader(header);
  return section;
}

function focusEndpointField(index, field, mode) {
  const section = openEndpointByIndex(index);
  if (!section) return false;
  if (!field) {
    highlightAndScroll(section);
    return true;
  }

  const needle = normalizeFocusToken(field);
  const selector = mode === 'response'
    ? 'tr[data-response-field]'
    : 'tr[data-param-name], tr[data-param-leaf], tr[data-param-label]';
  const rows = Array.from(section.querySelectorAll(selector));
  const row = rows.find((r) => {
    const values = [
      r.dataset.paramName,
      r.dataset.paramLeaf,
      r.dataset.paramLabel,
      r.dataset.responseField,
      r.textContent,
    ].filter(Boolean);
    return values.some((v) => normalizeFocusToken(v).includes(needle));
  });

  if (row) {
    highlightAndScroll(row, true);
    return true;
  }

  highlightAndScroll(section);
  return true;
}

function focusCommonOrErrorRow(doc, token) {
  const needle = normalizeFocusToken(token);
  if (!needle) return false;
  const rows = Array.from(document.querySelectorAll('.param-table tbody tr'));
  const row = rows.find((r) => normalizeFocusToken(r.textContent).includes(needle));
  if (!row) return false;
  highlightAndScroll(row, true);
  return true;
}

function applyApiReferenceFocusFromLocation() {
  const params = new URLSearchParams(window.location.search || '');
  const focusType = params.get('focusType');
  const field = params.get('field');
  const section = params.get('section');
  const query = params.get('q');
  const ep = Number.parseInt(params.get('ep') || '', 10);

  if (window.location.hash === '#headers') {
    if (typeof switchHeaderTab === 'function') switchHeaderTab('headers');
  }

  if (!focusType) return;

  if (focusType === 'header-section') {
    focusHeaderSection(section || query);
    return;
  }
  if (focusType === 'header-field') {
    if (!focusHeaderField(section, field || query)) {
      focusHeaderSection(section || 'system');
    }
    return;
  }
  if (focusType === 'endpoint') {
    const sectionEl = openEndpointByIndex(ep);
    if (sectionEl) highlightAndScroll(sectionEl);
    return;
  }
  if (focusType === 'request-param') {
    focusEndpointField(ep, field || query, 'request');
    return;
  }
  if (focusType === 'response-field') {
    focusEndpointField(ep, field || query, 'response');
    return;
  }
  if (focusType === 'common-code' || focusType === 'error-code') {
    focusCommonOrErrorRow(params.get('doc'), field || query);
  }
}

window.hapiApiReferenceApplyFocus = applyApiReferenceFocusFromLocation;
setTimeout(applyApiReferenceFocusFromLocation, 0);
</script>

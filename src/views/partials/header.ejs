<nav class="top-nav">
  <span class="nav-logo"><span>H</span>API Portal</span>
  <div class="nav-tabs">
    <a href="/home" class="nav-tab <%= currentMenu === 'home' ? 'active' : '' %>">HOME</a>
    <a href="/guide" class="nav-tab <%= currentMenu === 'guide' ? 'active' : '' %>">시작하기</a>
    <a href="/api-reference?doc=header" class="nav-tab <%= currentMenu === 'api-reference' ? 'active' : '' %>">API</a>
    <a href="/support" class="nav-tab <%= currentMenu === 'support' ? 'active' : '' %>">운영 지원</a>

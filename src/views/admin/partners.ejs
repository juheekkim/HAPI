<div class="admin-nav">
  <span class="admin-nav-title">⚙ 관리자 페이지</span>
  <span>|</span>
  <span>파트너사 코드 신청 관리</span>
</div>

<div class="admin-tabs">
  <a href="/admin/apis" class="admin-tab">🧩 API 등록/관리</a>
  <a href="/admin/menus" class="admin-tab">🗂 메뉴 관리</a>
  <a href="/admin/roles" class="admin-tab">🔑 권한 그룹 관리</a>
  <a href="/admin/partner-roles" class="admin-tab">🧑‍💼 사용자별 권한관리</a>
  <a href="/admin/partners" class="admin-tab active">👤 파트너사 코드 신청</a>
  <a href="/admin/firewall" class="admin-tab">🔓 방화벽·토큰 요청</a>
  <a href="/admin/inquiries" class="admin-tab">💬 문의 확인</a>
  <a href="/admin/notices" class="admin-tab">📢 공지사항 관리</a>
</div>

<div class="admin-content">
  <div class="admin-section-title">파트너사 코드 신청 목록</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">No</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">업체명</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">담당자명</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">이메일</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">연락처</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;min-width:240px;">연동 목적</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">신청일시</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">신청상태</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">처리</th>
        <th style="text-align:center;background:#d9e8fb;color:#5a7194;">업체코드</th>
      </tr>
    </thead>
    <tbody>
      <% if (partners.length === 0) { %>
      <tr><td colspan="10" style="text-align:center;color:#8a9bb0;padding:32px">신청 내역이 없습니다.</td></tr>
      <% } %>
      <% partners.forEach((p, idx) => { const rowNo = partners.length - idx; %>
      <tr>
        <td style="text-align:center;color:#8a9bb0;"><%= rowNo %></td>
        <td style="text-align:center;"><strong><%= p.company_name %></strong></td>
        <td style="text-align:center;"><%= p.manager_name %></td>
        <td style="text-align:center;"><%= p.email %></td>
        <td style="text-align:center;"><%= p.phone || '-' %></td>
        <td style="text-align:center;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= p.purpose || '-' %></td>
        <td class="mono" style="text-align:center;font-size:12px"><%= p.created_at ? new Date(p.created_at).toLocaleString('sv-SE', {timeZone:'Asia/Seoul'}).replace('T',' ').slice(0,19) : '-' %></td>
        <td style="text-align:center;">
          <% if (p.status === 'pending') { %>
            <span class="badge badge-pending">검토중</span>
          <% } else if (p.status === 'approved') { %>
            <span class="badge badge-approved">승인</span>
          <% } else { %>
            <span class="badge badge-rejected">반려</span>
            <% if (p.reject_reason) { %>
            <div style="font-size:11px;color:#8a9bb0;margin-top:2px"><%= p.reject_reason %></div>
            <% } %>
          <% } %>
        </td>
        <td style="text-align:center;">
          <% if (p.status === 'pending') { %>
          <div class="action-btns" style="justify-content:center;">
            <form action="/admin/partners/<%= p.id %>/approve" method="POST" style="display:inline">
              <button class="btn btn-success btn-sm" type="submit">승인</button>
            </form>
            <button class="btn btn-danger btn-sm" onclick="openRejectModal(<%= p.id %>)">반려</button>
          </div>
          <% } else { %>
          <div style="font-size:12px;color:#4a5568;line-height:1.5">
            <% if (p.processed_at) { %>
            <div class="mono" style="font-size:11px;color:#8a9bb0;margin-top:2px">
              <%= new Date(p.processed_at).toLocaleString('sv-SE', {timeZone:'Asia/Seoul'}).replace('T',' ').slice(0,19) %>
            </div>
            <% } %>
          </div>
          <% } %>
        </td>
        <td style="text-align:center;">
          <% if (p.partner_code) { %>
          <span class="mono" style="font-size:12px;font-weight:700;letter-spacing:2px;color:#2680eb"><%= p.partner_code %></span>
          <% } else { %>
          <span style="color:#c0c9d4">-</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- 반려 사유 모달 -->
<div id="modal-reject" class="modal-overlay" style="display:none">
  <div class="reject-modal">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <h3 style="font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px">
        <span style="color:#f59e0b">⚠</span> 반려 사유 입력
      </h3>
      <button onclick="closeRejectModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#8a9bb0">✕</button>
    </div>
    <form id="reject-form" method="POST">
      <textarea name="reason" placeholder="반려 사유를 입력해 주세요." rows="4"
        style="width:100%;padding:10px 12px;border:1.5px solid #dde3ea;border-radius:6px;font-family:inherit;font-size:13px;resize:none;outline:none;margin-bottom:16px"
        onfocus="this.style.borderColor='#2680eb'" onblur="this.style.borderColor='#dde3ea'"
      ></textarea>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" onclick="closeRejectModal()" class="btn btn-outline">취소</button>
        <button type="submit" class="btn btn-danger">반려 처리</button>
      </div>
    </form>
  </div>
</div>

<script>
function openRejectModal(id) {
  document.getElementById('reject-form').action = '/admin/partners/' + id + '/reject';
  document.getElementById('modal-reject').style.display = 'flex';
}
function closeRejectModal() {
  document.getElementById('modal-reject').style.display = 'none';
}
document.getElementById('modal-reject').addEventListener('click', function(e) {
  if (e.target === this) closeRejectModal();
});
</script>

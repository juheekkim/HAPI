PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/hapi_db
SESSION_SECRET=change-me
# API 등록 - 이미지 업로드 자동입력(Claude Vision)에 필요. 없으면 501로 비활성.
ANTHROPIC_API_KEY=
# API 등록 - "MCI 서비스 주소 가져오기"(엑셀/이미지와 나란한 3-way 자동입력 방식)에 필요. 없으면 501로 비활성.
MCI_SERVICE_BASE_URL=
# API Reference - "테스트" 샌드박스 기능에 필요. 없으면 501로 비활성.
# 최종 호출 URL = {SANDBOX_GATEWAY_BASE_URL}/{systemCode}/json.jdo (systemCode는 요청마다 다름, 예: OCH, LCB)
# 예: https://exgatedev.hanwharesort.co.kr:443/iGate
SANDBOX_GATEWAY_BASE_URL=
# 챗봇(우측 하단 위젯) - 사내 AI 허브 연동에 필요. 셋 다 없으면 501로 비활성. ANTHROPIC_API_KEY와는 별개의 전용 키.
# 호출 URL = {CHATBOT_LLM_BASE_URL}/{CHATBOT_LLM_MODEL}/invoke (예: https://.../api/hub/v1/models)
# 요청/응답은 OpenAI chat completions 형식으로 가정(허브 자체 문서 미확인, docs/chatbot.md 참고).
CHATBOT_LLM_API_KEY=ax-llm-8ww-Azu6r6rA82ynFHSZmHeAcROM8_d0
CHATBOT_LLM_BASE_URL=https://ito-ax.apps.dev.honecloud.co.kr/api/hub/v1/models
CHATBOT_LLM_MODEL=gpt-5.4-mini

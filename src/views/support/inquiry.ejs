<div class="community-hero">
  <h1>문의하기</h1>
  <p>궁금한 점이나 API 오류를 문의해주세요.</p>
</div>

<div class="community-tabs">
  <a href="/support" class="community-tab">📢 공지사항</a>
  <a href="/support/inquiry" class="community-tab active">✏ 문의하기</a>
  <a href="/support/firewall-apply" class="community-tab">🔒 방화벽/토큰 신청</a>
</div>

<div style="padding: 24px 32px; display: flex; gap: 24px; align-items: flex-start;">

  <!-- 왼쪽: 문의 등록 폼 -->
  <div style="width: 1000px; flex-shrink: 0;">
    <div class="comm-card">
      <div class="comm-card-title">✏ 문의 등록</div>

      <% if (success) { %>
      <div style="background:#dcfce7;border:1px solid #86efac;border-radius:8px;padding:12px 14px;margin-bottom:16px;color:#15803d;font-size:13px;">
        ✅ 문의가 등록되었습니다. 빠른 시일 내에 답변드리겠습니다.
      </div>
      <% } %>
      <% if (error) { %>
      <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:12px 14px;margin-bottom:16px;color:#dc2626;font-size:13px;">
        ⚠ <%= error %>
      </div>
      <% } %>

      <form action="/support/inquiry" method="POST">
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:12px;font-weight:700;margin-bottom:6px;color:#4a5568;">
            문의 내용 <span style="color:#ef4444;">*</span>
          </label>
          <textarea
            name="question"
            rows="8"
            required
            placeholder="문의 내용을 입력해주세요.&#10;오류 발생 시 HTTP 상태코드와 에러 메시지를 함께 기재해주세요."
            style="width:100%;padding:12px 14px;border:1.5px solid #dde3ea;border-radius:8px;font-size:13px;font-family:inherit;outline:none;resize:vertical;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2680eb'" onblur="this.style.borderColor='#dde3ea'"
          ></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">문의 등록</button>
      </form>
    </div>
  </div>

  <!-- 오른쪽: 내 문의 내역 -->
  <div style="flex: 1; min-width: 0;">
    <div class="comm-card">
      <div class="comm-card-title">📋 나의 문의 내역</div>

      <% if (myInquiries.length === 0) { %>
      <p style="color:#8a9bb0;font-size:13px;padding:16px 0;">등록된 문의가 없습니다.</p>
      <% } %>

      <% myInquiries.forEach((q, idx) => { %>
      <div style="border:1px solid #dde3ea;border-radius:8px;padding:16px;margin-bottom:12px;background:#fafbff;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:10px;">
          <!-- 왼쪽: 번호 + 상태 배지 -->
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;font-weight:700;color:#8a9bb0;">#<%= myInquiries.length - idx %></span>
            <% if (q.status === 'answered') { %>
              <span class="badge badge-approved">답변완료</span>
            <% } else { %>
              <span class="badge badge-pending">답변대기</span>
            <% } %>
          </div>
          <!-- 오른쪽: 일시 정보 -->
          <div style="font-size:11px;color:#a0aec0;text-align:right;display:flex;flex-direction:column;gap:2px;white-space:nowrap;">
            <span>📅 문의 <%= q.created_at ? new Date(q.created_at).toLocaleString('ko-KR', {timeZone:'Asia/Seoul'}) : '-' %></span>
            <% if (q.answered_at) { %>
            <span>✅ 답변 <%= new Date(q.answered_at).toLocaleString('ko-KR', {timeZone:'Asia/Seoul'}) %></span>
            <% } %>
          </div>
        </div>
        <div style="font-size:13px;color:#1a2332;font-weight:600;margin-bottom:8px;white-space:pre-wrap;">Q. <%= q.question %></div>
        <% if (q.answer) { %>
        <div style="font-size:13px;color:#374151;background:#f0f7ff;border-left:3px solid #2680eb;padding:10px 14px;border-radius:0 6px 6px 0;white-space:pre-wrap;">A. <%= q.answer %></div>
        <% } else { %>
        <div style="font-size:12px;color:#8a9bb0;font-style:italic;padding:6px 0;">답변을 준비 중입니다.</div>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>

</div>

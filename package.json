{
  "name": "hapi",
  "version": "1.0.0",
  "description": "리조트 API 플랫폼 포털",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:scripts": "node src/scripts/run-db-scripts.js",
    "db:scripts:debug": "node --inspect src/scripts/run-db-scripts.js",
    "db:setup": "node src/scripts/setup.js",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "multer": "^2.2.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true
  }
}

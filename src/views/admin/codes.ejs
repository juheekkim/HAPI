<script>
// 공통 코드/에러 코드/시스템 정보 페이지 내 탭 전환(헤더 문서 switchHeaderTab과 동일한 방식)
function switchCodeTab(tab) {
  var panels = { common: document.getElementById('ctab-common'), error: document.getElementById('ctab-error'), system: document.getElementById('ctab-system') };
  var btns = { common: document.getElementById('ctab-btn-common'), error: document.getElementById('ctab-btn-error'), system: document.getElementById('ctab-btn-system') };
  Object.keys(panels).forEach(function (key) {
    panels[key].style.display = key === tab ? '' : 'none';
    btns[key].classList.toggle('active', key === tab);
  });
}

function openCommonCreateModal() { document.getElementById('commonCreateModal').style.display = 'flex'; }
function closeCommonCreateModal() { document.getElementById('commonCreateModal').style.display = 'none'; }
function openCommonEditModal(id, groupCode, groupName, detailCode, description, displayOrder) {
  document.getElementById('commonEditForm').action = '/admin/codes/common/' + id + '/update';
  document.getElementById('commonEditGroupCode').value = groupCode;
  document.getElementById('commonEditGroupName').value = groupName;
  document.getElementById('commonEditDetailCode').value = detailCode;
  document.getElementById('commonEditDescription').value = description;
  document.getElementById('commonEditDisplayOrder').value = displayOrder;
  document.getElementById('commonEditModal').style.display = 'flex';
}
function closeCommonEditModal() { document.getElementById('commonEditModal').style.display = 'none'; }

function openErrorCreateModal() { document.getElementById('errorCreateModal').style.display = 'flex'; }
function closeErrorCreateModal() { document.getElementById('errorCreateModal').style.display = 'none'; }
function openErrorEditModal(code, name, desc) {
  document.getElementById('errorEditForm').action = '/admin/codes/error/' + encodeURIComponent(code) + '/update';
  document.getElementById('errorEditOriginalCode').value = code;
  document.getElementById('errorEditCode').value = code;
  document.getElementById('errorEditName').value = name;
  document.getElementById('errorEditDesc').value = desc;
  document.getElementById('errorEditModal').style.display = 'flex';
}
function closeErrorEditModal() { document.getElementById('errorEditModal').style.display = 'none'; }

function openSystemCreateModal() { document.getElementById('systemCreateModal').style.display = 'flex'; }
function closeSystemCreateModal() { document.getElementById('systemCreateModal').style.display = 'none'; }
function openSystemEditModal(id, systemName, systemCode, protocol, division, source, target, messageFormat, charset, remark, displayOrder) {
  document.getElementById('systemEditForm').action = '/admin/codes/system/' + id + '/update';
  document.getElementById('systemEditName').value = systemName;
  document.getElementById('systemEditCode').value = systemCode;
  document.getElementById('systemEditProtocol').value = protocol;
  document.getElementById('systemEditDivision').value = division;
  document.getElementById('systemEditSource').value = source;
  document.getElementById('systemEditTarget').value = target;
  document.getElementById('systemEditMessageFormat').value = messageFormat;
  document.getElementById('systemEditCharset').value = charset;
  document.getElementById('systemEditRemark').value = remark;
  document.getElementById('systemEditDisplayOrder').value = displayOrder;
  document.getElementById('systemEditModal').style.display = 'flex';
}
function closeSystemEditModal() { document.getElementById('systemEditModal').style.display = 'none'; }

// 모달 외부 클릭 시 닫기
[['commonCreateModal', closeCommonCreateModal], ['commonEditModal', closeCommonEditModal],
 ['errorCreateModal', closeErrorCreateModal], ['errorEditModal', closeErrorEditModal],
 ['systemCreateModal', closeSystemCreateModal], ['systemEditModal', closeSystemEditModal]].forEach(function(pair) {
  document.getElementById(pair[0]).addEventListener('click', function(e) {
    if (e.target === this) pair[1]();
  });
});

// 에러 발생 시(중복 코드 등) 서버가 error 메시지와 함께 렌더링 — 어떤 탭에서 실패했는지 알 수 없으므로
// 두 폼 다 유지된 채 첫 로드 상태(공통 코드 탭)로 보여준다. 사용자가 필요시 직접 탭 전환.
</script>

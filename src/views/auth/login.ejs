<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>로그인 — HAPI Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/common.css">
</head>
<body>
<div class="login-page">
  <!-- 왼쪽 브랜딩 패널 -->
  <div class="login-left">
    <div>
      <div class="login-brand-row">
        <div class="login-logo-badge">H</div>
        <div class="login-brand">Hanwha Hotels &amp; Resorts</div>
      </div>
      <div class="login-title">한화호텔앤드리조트<br>API Portal</div>
    </div>
    <ul class="login-features">
      <li>API 정보 통합 제공</li>
      <li>파트너사 관리</li>
      <li>방화벽 해제 신청</li>
      <li>공지사항/FAQ 확인</li>
    </ul>
    <div></div>
  </div>

  <!-- 오른쪽 폼 영역 -->
  <div class="login-right">
    <div class="login-box">

      <!-- 성공 메시지 -->
      <% if (success) { %>
      <div class="alert-success" style="margin-bottom:20px"><%= success %></div>
      <% } %>

      <!-- 로그인 폼 -->
      <div id="form-login">
        <h2>파트너사 로그인</h2>
        <p>등록된 파트너사 코드로 로그인하세요</p>
        <% if (error) { %>
        <div class="alert-error"><%= error %></div>
        <% } %>
        <form class="login-form" action="/auth/login" method="POST">
          <div class="form-group">
            <label>파트너사 코드</label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-partner-code"></span>
              <input type="text" name="partner_code" placeholder="파트너사 코드를 입력하세요" required>
            </div>
          </div>
          <div class="form-group">
            <label>비밀번호</label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-password"></span>
              <input type="password" name="password" placeholder="비밀번호를 입력하세요" required>
            </div>
          </div>
          <button class="btn-login" type="submit">로그인</button>
        </form>
        <div class="login-divider">파트너사 코드가 없으신가요?</div>
        <button class="btn-partner-apply" onclick="toggleForm('apply')">
          🏢 파트너사 코드 신청
        </button>
      </div>

      <!-- 파트너사 신청 폼 -->
      <div id="form-apply" style="display:none">
        <h2>파트너사 코드 신청</h2>
        <p>신청 완료 후 검토를 거쳐 이메일로 안내드립니다</p>
        <form class="login-form" action="/auth/apply" method="POST">
          <div class="form-group">
            <label>업체명 <span style="color:#ef4444">*</span></label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-company"></span>
              <input type="text" name="company_name" placeholder="업체명을 입력하세요" required>
            </div>
          </div>
          <div class="form-group">
            <label>담당자명 <span style="color:#ef4444">*</span></label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-manager"></span>
              <input type="text" name="manager_name" placeholder="담당자 성함을 입력하세요" required>
            </div>
          </div>
          <div class="form-group">
            <label>담당자 이메일 <span style="color:#ef4444">*</span></label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-email"></span>
              <input type="email" name="email" placeholder="example@partner.co.kr" required>
            </div>
          </div>
          <div class="form-group">
            <label>담당자 연락처</label>
            <div class="input-icon-wrap">
              <span class="input-icon input-icon-phone"></span>
              <input type="text" name="phone" placeholder="010-0000-0000">
            </div>
          </div>
          <div class="form-group">
            <label>연동 목적</label>
            <textarea name="purpose" rows="3" placeholder="API 연동 목적을 간략히 기재해주세요" style="width:100%;padding:10px 12px;border:1.5px solid #dde3ea;border-radius:8px;font-size:14px;font-family:inherit;outline:none;resize:none"></textarea>
          </div>
          <button class="btn-login" type="submit">신청하기</button>
        </form>
        <div class="login-divider">이미 계정이 있으신가요?</div>
        <button class="btn-partner-apply" onclick="toggleForm('login')">← 로그인으로 돌아가기</button>
      </div>

    </div>
  </div>
</div>

<script>
  function toggleForm(which) {
    document.getElementById('form-login').style.display = which === 'login' ? '' : 'none';
    document.getElementById('form-apply').style.display = which === 'apply' ? '' : 'none';
  }
</script>
</body>
</html>

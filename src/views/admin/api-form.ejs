<div class="admin-nav">
  <span class="admin-nav-title">⚙ 관리자 페이지</span>
  <span>|</span>
  <span><%= mode === 'edit' ? 'API 수정' : 'API 등록' %></span>
</div>

<div class="admin-tabs">
  <a href="/admin/apis" class="admin-tab active">🧩 API 등록/관리</a>
  <a href="/admin/codes" class="admin-tab">🔖 코드 관리</a>
  <a href="/admin/menus" class="admin-tab">🗂 메뉴 관리</a>
  <a href="/admin/roles" class="admin-tab">🔑 권한 그룹 관리</a>
  <a href="/admin/partner-roles" class="admin-tab">🧑‍💼 사용자별 권한관리</a>
  <a href="/admin/partners" class="admin-tab">👤 파트너사 코드 신청</a>
  <a href="/admin/firewall" class="admin-tab">🔓 방화벽·토큰 요청</a>
  <a href="/admin/inquiries" class="admin-tab">💬 문의 확인</a>
  <a href="/admin/notices" class="admin-tab">📢 공지사항 관리</a>
</div>

<div class="admin-content">
  <div class="admin-section-title" style="display:flex;align-items:center;justify-content:space-between;">
    <span><%= mode === 'edit' ? 'API 수정' : '새 API 등록' %></span>
    <a href="/admin/apis" style="font-size:13px;color:#4a5568;">← 목록으로</a>
  </div>

  <% if (error) { %>
  <div style="background:#fee2e2;border:1px solid #fca5a5;color:#b91c1c;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;">
    ⚠ <%= error %>
  </div>
  <% } %>

  <% if (mode !== 'edit') { %>
  <!-- 등록 방식 선택: 수기 작성 / 엑셀 업로드 / MCI 서비스 주소 가져오기.
       엑셀·MCI는 결과를 아래 수기 작성 폼과 동일한 필드에 주입(applyImportedSpec)할 뿐,
       실제 등록/수정은 여전히 기존 apiForm 제출로 이루어진다. -->
  <div class="admin-section-title" style="margin-bottom:10px;">등록 방식 선택</div>
  <div style="display:flex;gap:8px;margin-bottom:18px;">
    <button type="button" class="btn btn-sm btn-primary import-mode-tab" data-mode="manual">✍ 수기 작성</button>
    <button type="button" class="btn btn-sm import-mode-tab" data-mode="excel">📄 엑셀 업로드</button>
    <button type="button" class="btn btn-sm import-mode-tab" data-mode="image">🖼 이미지 업로드</button>
    <button type="button" class="btn btn-sm import-mode-tab" data-mode="mci">🔗 MCI 서비스 주소 가져오기</button>
  </div>

  <div id="importPanel-excel" class="import-panel" style="display:none;border:1px dashed #93c5fd;border-radius:8px;padding:16px;margin-bottom:18px;background:#f8fafc;">
    <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">엑셀 파일 선택 (.xlsx)</label>
    <input type="file" id="excelFile" accept=".xlsx,.xls">
    <div id="excelImportMsg" style="font-size:12px;color:#6b7280;margin-top:8px;"></div>
    <select id="excelSpecPicker" style="display:none;margin-top:10px;width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></select>
  </div>

  <div id="importPanel-image" class="import-panel" style="display:none;border:1px dashed #93c5fd;border-radius:8px;padding:16px;margin-bottom:18px;background:#f8fafc;">
    <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">이미지 파일 선택 (.png, .jpg, 여러 장 선택 가능 — 이미지 1장 = 엔드포인트 1개)</label>
    <input type="file" id="imageFile" accept="image/*" multiple>
    <div id="imageImportMsg" style="font-size:12px;color:#6b7280;margin-top:8px;"></div>
    <select id="imageSpecPicker" style="display:none;margin-top:10px;width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></select>
  </div>

  <div id="importPanel-mci" class="import-panel" style="display:none;border:1px dashed #93c5fd;border-radius:8px;padding:16px;margin-bottom:18px;background:#f8fafc;">
    <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">MCI 서비스 주소</label>
    <input type="text" id="mciAddress" placeholder="예: /svc/condo-reserve" style="width:60%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
    <div id="mciImportMsg" style="font-size:12px;color:#6b7280;margin-top:8px;"></div>
  </div>

  <div id="autoFillWrap" style="display:none;text-align:right;margin-bottom:12px;">
    <button type="button" id="autoFillBtn" class="btn btn-primary btn-sm" onclick="runAutoFill()">자동입력</button>
  </div>
  <% } %>

  <form id="apiForm" method="POST"
    action="<%= mode === 'edit' ? '/admin/apis/' + apiSpec.id + '/update' : '/admin/apis' %>">

    <div style="border:1px solid #dde3ea;border-radius:8px;padding:20px;margin-bottom:20px;">
      <div style="display:grid;grid-template-columns:160px 1fr;gap:14px;margin-bottom:14px;">
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">카테고리</label>
          <select name="category" required
            style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
            <option value="resort" <%= apiSpec && apiSpec.category === 'resort' ? 'selected' : '' %>>리조트</option>
            <option value="estate" <%= apiSpec && apiSpec.category === 'estate' ? 'selected' : '' %>>에스테이트</option>
            <option value="common" <%= apiSpec && apiSpec.category === 'common' ? 'selected' : '' %>>공통</option>
          </select>
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">도메인 코드 (고유값, 예: condo)</label>
          <input type="text" name="domain" required placeholder="예: condo"
            value="<%= apiSpec ? apiSpec.domain : '' %>"
            style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;font-family:monospace;">
          <div id="domainSuggestion" style="display:none;font-size:11.5px;color:#2563eb;margin-top:5px;cursor:pointer;"></div>
        </div>
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">API 명칭</label>
        <input type="text" name="name" required placeholder="예: 콘도 예약 API"
          value="<%= apiSpec ? apiSpec.name : '' %>"
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">설명</label>
        <textarea name="description" rows="3" placeholder="API 설명"
          style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"><%= apiSpec ? apiSpec.description : '' %></textarea>
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">노출 순서 (숫자가 작을수록 먼저 표시)</label>
        <input type="number" name="display_order" value="<%= apiSpec && apiSpec.display_order != null ? apiSpec.display_order : 0 %>"
          style="width:120px;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
      </div>
    </div>

    <div class="admin-section-title" style="display:flex;align-items:center;justify-content:space-between;">
      <span>Request / Response 엔드포인트</span>
      <button type="button" class="btn btn-primary btn-sm" onclick="addEndpoint()">+ 엔드포인트 추가</button>
    </div>

    <div id="endpointsContainer"></div>

    <input type="hidden" name="endpoints_json" id="endpointsJson">

    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
      <a href="/admin/apis" class="btn btn-sm" style="border:1px solid #d1d5db;background:#fff;color:#374151;">취소</a>
      <button type="submit" class="btn btn-primary btn-sm"><%= mode === 'edit' ? '저장' : '등록' %></button>
    </div>
  </form>
</div>

<!-- 엔드포인트 블록 템플릿 -->
<template id="endpointTemplate">
  <div class="endpoint-block" style="border:1px solid #dde3ea;border-radius:8px;padding:16px;margin-bottom:16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <strong style="color:#1e40af;font-size:13px;">엔드포인트 <span class="ep-number"></span></strong>
      <button type="button" class="btn btn-sm" style="background:#fca5a5;color:#b91c1c;border:none;"
        onclick="this.closest('.endpoint-block').remove(); renumberEndpoints();">엔드포인트 삭제</button>
    </div>
    <div style="display:grid;grid-template-columns:110px 1fr 1fr;gap:10px;margin-bottom:12px;">
      <select class="ep-method" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
        <option>GET</option><option>POST</option><option>PUT</option><option>DELETE</option><option>PATCH</option>
      </select>
      <input type="text" class="ep-url" placeholder="HBSGOLOCH0119 (SVC ID) 또는 /api/v1/resort/condo/reserve"
        style="padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;font-family:monospace;box-sizing:border-box;">
      <input type="text" class="ep-description" placeholder="엔드포인트 설명 (예: 예약 등록)"
        style="padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;box-sizing:border-box;">
    </div>
    <div style="font-size:11px;color:#8a9bb0;margin:-6px 0 12px;">
      URL이 "/"로 시작하지 않는 SVC ID 형태(예: <span class="mono">HBSGOLOCH0119</span>)일 때만 API Reference 화면에 🧪 테스트 버튼이 노출됩니다. "/"로 시작하는 REST 경로는 실제 게이트웨이 매핑이 없어 테스트 버튼이 보이지 않습니다.
    </div>
    <div class="ep-params-wrap" style="margin-bottom:12px;">
      <table class="param-table">
        <thead>
          <tr>
            <th>파라미터ID</th>
            <th>파라미터명</th>
            <th style="width:120px;">Data Type</th>
            <th style="width:60px;">필수</th>
            <th>설명</th>
            <th style="width:100px;"></th>
          </tr>
        </thead>
        <tbody class="ep-params-body"></tbody>
      </table>
      <button type="button" class="btn btn-sm" style="margin-top:8px;"
        onclick="addParamRow(this.parentElement.querySelector('.ep-params-body')); updateDataPreview(this.closest('.endpoint-block'));">+ 파라미터 추가</button>
      <div style="font-size:11px;color:#8a9bb0;margin-top:6px;">
        파라미터ID에 점(.)을 포함하면(예: <span class="mono">ds_inSearch.CORP_CD</span>) 접두사(<span class="mono">ds_inSearch</span>)가 실제 전송 시 <span class="mono">Data</span> 하위의 배열로 그룹핑됩니다(API Reference 테스트 샌드박스와 동일 규칙). 점이 없으면 <span class="mono">Data</span> 바로 아래에 값으로 들어갑니다. 아래 미리보기에서 실제 봉투 모양을 확인하세요.
      </div>
      <div style="margin-top:8px;">
        <label style="font-size:11px;font-weight:600;color:#64748b;display:block;margin-bottom:4px;">Data 봉투 미리보기 (읽기 전용)</label>
        <pre class="ep-data-preview code-block" style="font-size:11px;padding:8px 10px;margin:0;">{}</pre>
      </div>
    </div>
    <div class="ep-response-wrap">
      <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">응답 예시 필드 (선택)</label>
      <table class="param-table">
        <thead>
          <tr>
            <th>필드ID</th>
            <th>필드명</th>
            <th style="width:120px;">Data Type</th>
            <th>예시 값</th>
            <th>설명</th>
            <th style="width:100px;"></th>
          </tr>
        </thead>
        <tbody class="ep-response-body"></tbody>
      </table>
      <button type="button" class="btn btn-sm" style="margin-top:8px;"
        onclick="addResponseRow(this.parentElement.querySelector('.ep-response-body')); updateResponsePreview(this.closest('.endpoint-block'));">+ 필드 추가</button>
      <div style="font-size:11px;color:#8a9bb0;margin-top:6px;">
        필드ID에 점(.)을 포함하면(예: <span class="mono">ds_prcsResult.PROC_CD</span>) 접두사(<span class="mono">ds_prcsResult</span>)가 응답 예시에서 배열로 그룹핑됩니다(요청 파라미터와 동일 규칙). 점이 없으면 최상위에 값으로 들어갑니다. 아래 미리보기에서 실제 저장될 JSON을 확인하세요.
      </div>
      <div style="margin-top:8px;">
        <label style="font-size:11px;font-weight:600;color:#64748b;display:block;margin-bottom:4px;">응답 예시 JSON 미리보기 (읽기 전용, 저장 시 이 내용이 저장됩니다)</label>
        <pre class="ep-response-preview code-block" style="font-size:11px;padding:8px 10px;margin:0;">{}</pre>
      </div>
    </div>
  </div>
</template>

<!-- 파라미터 행 템플릿 -->
<template id="paramRowTemplate">
  <tr class="param-row">
    <td><input type="text" class="param-name" placeholder="파라미터ID"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td><input type="text" class="param-label" placeholder="파라미터명"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td>
      <select class="param-type" style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;">
        <option>String</option><option>Integer</option><option>Number</option><option>Boolean</option><option>Object</option><option>Array</option>
      </select>
    </td>
    <td style="text-align:center;"><input type="checkbox" class="param-required"></td>
    <td><input type="text" class="param-desc" placeholder="설명"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td style="text-align:center;">
      <button type="button" class="btn btn-sm" style="background:#fca5a5;color:#b91c1c;border:none;padding:6px 14px;"
        onclick="const block = this.closest('.endpoint-block'); this.closest('tr').remove(); updateDataPreview(block);">삭제</button>
    </td>
  </tr>
</template>

<!-- 응답 예시 필드 행 템플릿(요청 파라미터 행과 동일 구조 + "예시 값" 칸) -->
<template id="responseRowTemplate">
  <tr class="response-row">
    <td><input type="text" class="response-name" placeholder="필드ID"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td><input type="text" class="response-label" placeholder="필드명"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td>
      <select class="response-type" style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;">
        <option>String</option><option>Integer</option><option>Number</option><option>Boolean</option><option>Object</option><option>Array</option>
      </select>
    </td>
    <td><input type="text" class="response-example" placeholder="예시 값"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td><input type="text" class="response-desc" placeholder="설명"
      style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:12px;box-sizing:border-box;"></td>
    <td style="text-align:center;">
      <button type="button" class="btn btn-sm" style="background:#fca5a5;color:#b91c1c;border:none;padding:6px 14px;"
        onclick="const block = this.closest('.endpoint-block'); this.closest('tr').remove(); updateResponsePreview(block);">삭제</button>
    </td>
  </tr>
</template>

<script>
// 파라미터ID의 점(.) 표기를 Data 배열로 그룹핑하는 규칙(business-rules.md §10)을 API Reference
// 테스트 샌드박스(index.ejs의 buildDataSection)와 동일하게 재현한 미리보기 전용 함수.
function buildDataPreview(block) {
  const top = {};
  const groups = {};
  block.querySelectorAll('.param-row').forEach((row) => {
    const name = row.querySelector('.param-name').value.trim();
    if (!name) return;
    const parts = name.split('.');
    if (parts.length === 1) {
      top[parts[0]] = null;
    } else {
      const prefix = parts[0];
      const leaf = parts.slice(1).join('.');
      groups[prefix] = groups[prefix] || {};
      groups[prefix][leaf] = null;
    }
  });
  const data = Object.assign({}, top);
  Object.keys(groups).forEach((prefix) => { data[prefix] = [groups[prefix]]; });
  return data;
}

function updateDataPreview(block) {
  if (!block) return;
  const pre = block.querySelector('.ep-data-preview');
  if (!pre) return;
  pre.textContent = JSON.stringify({ Data: buildDataPreview(block) }, null, 2);
}

// 응답 예시 "예시 값" 칸은 텍스트지만 Data Type에 맞춰 실제 JSON 타입으로 변환해 저장한다
// (숫자/불리언 필드가 문자열 "0"/"true"로 저장돼 응답 표의 Data type과 어긋나지 않도록).
function coerceExampleValue(raw, type) {
  if (raw === '' || raw === undefined) return null;
  if (type === 'Number' || type === 'Integer') {
    const n = Number(raw);
    return Number.isNaN(n) ? raw : n;
  }
  if (type === 'Boolean') return raw === 'true';
  return raw;
}

// 응답 예시 필드 행 → 실제 저장될 JSON. 요청 파라미터와 동일한 점(.) 그룹핑 규칙(business-rules.md
// §10 — 접두사는 항상 배열로 감싸짐)을 그대로 적용하되, null 대신 admin이 입력한 예시 값을 채운다.
function buildResponsePreview(block) {
  const top = {};
  const groups = {};
  block.querySelectorAll('.response-row').forEach((row) => {
    const name = row.querySelector('.response-name').value.trim();
    if (!name) return;
    const type = row.querySelector('.response-type').value;
    const example = coerceExampleValue(row.querySelector('.response-example').value.trim(), type);
    const parts = name.split('.');
    if (parts.length === 1) {
      top[parts[0]] = example;
    } else {
      const prefix = parts[0];
      const leaf = parts.slice(1).join('.');
      groups[prefix] = groups[prefix] || {};
      groups[prefix][leaf] = example;
    }
  });
  const data = Object.assign({}, top);
  Object.keys(groups).forEach((prefix) => { data[prefix] = [groups[prefix]]; });
  return data;
}

function updateResponsePreview(block) {
  if (!block) return;
  const pre = block.querySelector('.ep-response-preview');
  if (!pre) return;
  pre.textContent = JSON.stringify(buildResponsePreview(block), null, 2);
}

function addResponseRow(tbody, field) {
  const tpl = document.getElementById('responseRowTemplate');
  const row = tpl.content.firstElementChild.cloneNode(true);
  if (field) {
    row.querySelector('.response-name').value = field.name || '';
    row.querySelector('.response-label').value = field.label || '';
    row.querySelector('.response-type').value = field.type || 'String';
    row.querySelector('.response-example').value =
      field.example === undefined || field.example === null ? '' : String(field.example);
    row.querySelector('.response-desc').value = field.desc || '';
  }
  tbody.appendChild(row);
}

function makeResponseFieldFromValue(name, value, stringifyWhole) {
  let type = 'String';
  if (typeof value === 'number') type = 'Number';
  else if (typeof value === 'boolean') type = 'Boolean';
  const example = stringifyWhole ? JSON.stringify(value) : (value === null ? '' : String(value));
  return { name, label: '', type, example, desc: '' };
}

// 기존(수정 모드) responseExample JSON 문자열 → 필드 행. 요청과 동일하게 "접두사.리프 = 배열"
// 형태만 정확히 역변환하고, 이 규칙에 안 맞는 값(배열이 아닌 중첩 객체 등 예전 데이터)은 값 손실
// 없이 JSON 문자열 그대로 한 행에 담아 보존한다(응답 예시엔 원래 필드명/설명 메타데이터가 없어
// label/desc는 항상 빈 값 — architecture.md 기존 규칙과 동일).
function flattenResponseExampleToFields(responseExampleStr) {
  if (!responseExampleStr) return [];
  let parsed;
  try {
    parsed = JSON.parse(responseExampleStr);
  } catch (e) {
    return null;
  }
  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;
  const fields = [];
  Object.keys(parsed).forEach((key) => {
    const value = parsed[key];
    if (Array.isArray(value)) {
      const item = value[0];
      if (item !== null && typeof item === 'object' && !Array.isArray(item)) {
        Object.keys(item).forEach((leaf) => {
          fields.push(makeResponseFieldFromValue(key + '.' + leaf, item[leaf]));
        });
      } else {
        fields.push(makeResponseFieldFromValue(key, value, true));
      }
      return;
    }
    if (value !== null && typeof value === 'object') {
      fields.push(makeResponseFieldFromValue(key, value, true));
      return;
    }
    fields.push(makeResponseFieldFromValue(key, value));
  });
  return fields;
}

function addParamRow(tbody, param) {
  const tpl = document.getElementById('paramRowTemplate');
  const row = tpl.content.firstElementChild.cloneNode(true);
  if (param) {
    // 구버전 데이터(label 없이 desc에 한글명이 들어있던 시절) 호환: label이 없으면
    // desc 값을 파라미터명으로 옮기고 설명은 비워서 새 컬럼 구조로 자연스럽게 보이게 한다.
    const hasLabel = param.label !== undefined && param.label !== null && param.label !== '';
    row.querySelector('.param-name').value = param.name || '';
    row.querySelector('.param-label').value = hasLabel ? param.label : (param.desc || '');
    row.querySelector('.param-type').value = param.type || 'String';
    row.querySelector('.param-required').checked = !!param.required;
    row.querySelector('.param-desc').value = hasLabel ? (param.desc || '') : '';
  }
  tbody.appendChild(row);
}

function addEndpoint(endpoint) {
  const tpl = document.getElementById('endpointTemplate');
  const block = tpl.content.firstElementChild.cloneNode(true);
  document.getElementById('endpointsContainer').appendChild(block);
  if (endpoint) {
    block.querySelector('.ep-method').value = endpoint.method || 'GET';
    block.querySelector('.ep-url').value = endpoint.url || '';
    block.querySelector('.ep-description').value = endpoint.description || '';
    const tbody = block.querySelector('.ep-params-body');
    (endpoint.params || []).forEach((p) => addParamRow(tbody, p));
    const responseTbody = block.querySelector('.ep-response-body');
    const fields = flattenResponseExampleToFields(endpoint.responseExample);
    if (fields === null) {
      // JSON이 아니거나(레거시 텍스트) 최상위가 배열/원시값 — 통짜로 한 행에 보존해 값 손실 방지.
      addResponseRow(responseTbody, {
        name: '_raw',
        example: endpoint.responseExample || '',
        desc: '(자동 변환 불가 원본 — 확인 후 수정)',
      });
    } else {
      fields.forEach((f) => addResponseRow(responseTbody, f));
    }
  }
  renumberEndpoints();
  updateDataPreview(block);
  updateResponsePreview(block);
  return block;
}

// 파라미터ID/응답 필드ID 등 입력칸 어디서든 타이핑하면(이벤트 위임) 해당 엔드포인트의
// Data/응답 미리보기를 갱신.
document.getElementById('endpointsContainer').addEventListener('input', (e) => {
  const block = e.target.closest('.endpoint-block');
  if (e.target.classList.contains('param-name')) updateDataPreview(block);
  if (
    e.target.classList.contains('response-name') ||
    e.target.classList.contains('response-example') ||
    e.target.classList.contains('response-type')
  ) {
    updateResponsePreview(block);
  }
});
// Data Type <select>는 input이 아니라 change 이벤트만 발생시키므로 별도로 위임한다.
document.getElementById('endpointsContainer').addEventListener('change', (e) => {
  if (!e.target.classList.contains('response-type')) return;
  updateResponsePreview(e.target.closest('.endpoint-block'));
});

// 엔드포인트 추가/삭제 시 "엔드포인트 #N" 표시를 현재 순서대로 갱신
function renumberEndpoints() {
  document.querySelectorAll('#endpointsContainer .endpoint-block').forEach((block, idx) => {
    const numEl = block.querySelector('.ep-number');
    if (numEl) numEl.textContent = '#' + (idx + 1);
  });
}

// 수정 모드일 때 기존 엔드포인트 데이터로 초기화
const initialEndpoints = <%- JSON.stringify((apiSpec && apiSpec.endpoints) || []).replace(/</g, '\\u003c') %>;
initialEndpoints.forEach((ep) => addEndpoint(ep));

document.getElementById('apiForm').addEventListener('submit', function () {
  const blocks = document.querySelectorAll('#endpointsContainer .endpoint-block');
  const endpoints = Array.from(blocks).map((block) => {
    const params = Array.from(block.querySelectorAll('.param-row')).map((row) => ({
      name: row.querySelector('.param-name').value.trim(),
      label: row.querySelector('.param-label').value.trim(),
      type: row.querySelector('.param-type').value,
      required: row.querySelector('.param-required').checked,
      desc: row.querySelector('.param-desc').value.trim(),
    }));
    const responseData = buildResponsePreview(block);
    const responseExample = Object.keys(responseData).length > 0
      ? JSON.stringify(responseData, null, 2)
      : null;
    return {
      method: block.querySelector('.ep-method').value,
      url: block.querySelector('.ep-url').value.trim(),
      description: block.querySelector('.ep-description').value.trim(),
      params,
      responseExample,
    };
  });
  document.getElementById('endpointsJson').value = JSON.stringify(endpoints);
});

// ── 등록 방식 탭 전환 ──
document.querySelectorAll('.import-mode-tab').forEach((tab) => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.import-mode-tab').forEach((t) => t.classList.remove('btn-primary'));
    tab.classList.add('btn-primary');
    document.querySelectorAll('.import-panel').forEach((p) => (p.style.display = 'none'));
    const panel = document.getElementById('importPanel-' + tab.dataset.mode);
    if (panel) panel.style.display = 'block';
    document.getElementById('autoFillWrap').style.display = tab.dataset.mode === 'manual' ? 'none' : 'block';
  });
});

// 등록 방식 탭에서 선택된 모드에 맞춰 실제 자동입력 함수로 위임
function runAutoFill() {
  const activeTab = document.querySelector('.import-mode-tab.btn-primary');
  const mode = activeTab ? activeTab.dataset.mode : 'manual';
  if (mode === 'excel') return importFromExcel();
  if (mode === 'image') return importFromImage();
  if (mode === 'mci') return importFromMci();
}

// ── 데이터 바인딩 슬롯: 엑셀/MCI 결과(ApiSpecInput)를 수기 작성 폼에 그대로 주입한다.
// 엑셀 업로드·MCI 조회 기능이 나중에 무엇으로 구현되더라도, 이 함수 하나에만 맞춰 결과를
// 넘기면 되므로 수기 작성 폼/제출 로직은 전혀 손댈 필요가 없다.
// 도메인 코드 추천 표시 — 값을 입력창에 바로 채우지 않고 클릭해야 적용되는 힌트로만 보여준다.
function showDomainSuggestion(suggested) {
  const domainInput = document.querySelector('[name="domain"]');
  const hint = document.getElementById('domainSuggestion');
  if (!suggested || domainInput.value.trim()) {
    hint.style.display = 'none';
    return;
  }
  hint.innerHTML = '💡 추천 도메인 코드: <strong>' + suggested + '</strong> (클릭하면 적용)';
  hint.style.display = 'block';
  hint.onclick = () => {
    domainInput.value = suggested;
    hint.style.display = 'none';
  };
}

function applyImportedSpec(spec) {
  if (!spec) return;
  document.querySelector('[name="category"]').value = spec.category || 'resort';
  // 도메인 코드는 실제 서비스 식별자라 자동으로 채워 넣지 않는다 — 추천값만 보여주고,
  // 관리자가 직접 클릭해서 적용할지 판단하게 한다(오등록/충돌 방지).
  showDomainSuggestion(spec.domain);
  document.querySelector('[name="name"]').value = spec.name || '';
  document.querySelector('[name="description"]').value = spec.description || '';
  document.querySelector('[name="display_order"]').value = spec.displayOrder || 0;
  document.getElementById('endpointsContainer').innerHTML = '';
  (spec.endpoints || []).forEach((ep) => addEndpoint(ep));
}

async function importFromExcel() {
  const fileInput = document.getElementById('excelFile');
  const msg = document.getElementById('excelImportMsg');
  const picker = document.getElementById('excelSpecPicker');
  if (!fileInput.files.length) {
    msg.textContent = '파일을 선택하세요.';
    return;
  }
  msg.textContent = '불러오는 중...';
  try {
    const formData = new FormData();
    formData.append('file', fileInput.files[0]);
    const result = await apiClient.upload('/admin/apis/import/excel', formData);
    picker.innerHTML = result.specs
      .map((s, i) => `<option value="${i}">${s.name} (${s.domain})</option>`)
      .join('');
    picker.style.display = result.specs.length > 1 ? 'block' : 'none';
    picker.onchange = () => applyImportedSpec(result.specs[picker.value]);
    applyImportedSpec(result.specs[0]);
    msg.textContent = `${result.specs.length}건을 불러왔습니다. 내용을 확인한 뒤 등록 버튼을 누르세요.`;
  } catch (err) {
    msg.textContent = err.message || '엑셀 불러오기 중 오류가 발생했습니다.';
  }
}

async function importFromImage() {
  const fileInput = document.getElementById('imageFile');
  const msg = document.getElementById('imageImportMsg');
  const picker = document.getElementById('imageSpecPicker');
  if (!fileInput.files.length) {
    msg.textContent = '파일을 선택하세요.';
    return;
  }
  msg.textContent = `이미지 ${fileInput.files.length}장 분석 중... (파일당 수 초 소요될 수 있습니다)`;
  try {
    const formData = new FormData();
    Array.from(fileInput.files).forEach((f) => formData.append('files', f));
    const result = await apiClient.upload('/admin/apis/import/image', formData);
    picker.innerHTML = result.specs
      .map((s, i) => `<option value="${i}">${s.name} (${s.domain})</option>`)
      .join('');
    picker.style.display = result.specs.length > 1 ? 'block' : 'none';
    picker.onchange = () => applyImportedSpec(result.specs[picker.value]);
    applyImportedSpec(result.specs[0]);
    msg.textContent = `${result.specs.length}건을 불러왔습니다. 내용을 확인한 뒤 등록 버튼을 누르세요.`;
  } catch (err) {
    msg.textContent = err.message || '이미지 불러오기 중 오류가 발생했습니다.';
  }
}

async function importFromMci() {
  const address = document.getElementById('mciAddress').value.trim();
  const msg = document.getElementById('mciImportMsg');
  if (!address) {
    msg.textContent = 'MCI 서비스 주소를 입력하세요.';
    return;
  }
  msg.textContent = '조회 중...';
  try {
    const result = await apiClient.post('/admin/apis/import/mci', { address });
    applyImportedSpec(result.specs[0]);
    msg.textContent = '불러온 내용을 확인한 뒤 등록 버튼을 누르세요.';
  } catch (err) {
    msg.textContent = err.message || 'MCI 서비스 조회 중 오류가 발생했습니다.';
  }
}
</script>
